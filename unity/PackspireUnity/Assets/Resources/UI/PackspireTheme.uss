.packspire-root {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    -unity-font-definition: resource("Fonts/KleeOne-Regular");
    color: rgb(48, 30, 16);
}

.ps-screen-host,
.ps-transition-host,
.ps-home-screen,
.ps-book-screen {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
}

.ps-screen-host {
    transition-property: opacity, translate;
    transition-duration: 0.18s;
}

.ps-transition-host {
    display: none;
}

.ps-home-screen {
    padding: 12px;
    background-color: rgb(35, 24, 16);
}

.ps-home-book-scene {
    position: relative;
    flex-grow: 1;
    min-height: 500px;
    margin-top: 6px;
    margin-bottom: 6px;
    overflow: hidden;
    background-color: rgb(31, 37, 29);
    border-left-width: 2px;
    border-right-width: 2px;
    border-top-width: 2px;
    border-bottom-width: 2px;
    border-left-color: rgba(102, 61, 23, 0.72);
    border-right-color: rgba(102, 61, 23, 0.72);
    border-top-color: rgba(102, 61, 23, 0.72);
    border-bottom-color: rgba(102, 61, 23, 0.72);
    border-top-left-radius: 7px;
    border-top-right-radius: 7px;
    border-bottom-left-radius: 7px;
    border-bottom-right-radius: 7px;
}

.ps-tabletop {
    flex-grow: 1;
    flex-direction: row;
    overflow: hidden;
    background-color: rgb(58, 39, 25);
    border-left-width: 3px;
    border-right-width: 3px;
    border-top-width: 3px;
    border-bottom-width: 3px;
    border-left-color: rgb(105, 70, 34);
    border-right-color: rgb(105, 70, 34);
    border-top-color: rgb(105, 70, 34);
    border-bottom-color: rgb(105, 70, 34);
    border-top-left-radius: 12px;
    border-top-right-radius: 12px;
    border-bottom-left-radius: 12px;
    border-bottom-right-radius: 12px;
}

.ps-home-scene {
    position: relative;
    width: 57%;
    overflow: hidden;
    background-color: rgb(31, 37, 29);
}

.ps-home-index {
    width: 43%;
    padding: 22px 24px 18px 24px;
    background-color: rgb(211, 188, 147);
    border-left-width: 5px;
    border-left-color: rgb(74, 44, 20);
}

.ps-home-background,
.ps-home-vignette {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
}

.ps-home-vignette {
    background-color: rgba(10, 14, 10, 0.18);
}

.ps-home-character {
    position: absolute;
    left: 28%;
    bottom: -3%;
    width: 44%;
    height: 79%;
}

.ps-home-profile,
.ps-home-footer {
    position: absolute;
    left: 22px;
    padding: 12px 17px;
    background-color: rgba(19, 22, 17, 0.88);
    border-left-width: 5px;
    border-left-color: rgb(199, 145, 48);
    border-top-left-radius: 5px;
    border-top-right-radius: 5px;
    border-bottom-left-radius: 5px;
    border-bottom-right-radius: 5px;
}

.ps-home-profile {
    top: 20px;
    min-width: 290px;
}

.ps-home-footer {
    bottom: 18px;
    min-width: 390px;
}

.ps-home-profile .ps-title,
.ps-home-profile .ps-body,
.ps-home-footer .ps-body {
    color: rgb(248, 226, 177);
}

.ps-index-heading {
    height: 70px;
    margin-bottom: 8px;
    border-bottom-width: 2px;
    border-bottom-color: rgba(91, 55, 24, 0.55);
}

.ps-index-heading .ps-title {
    font-size: 30px;
}

.ps-home-entry {
    flex-grow: 1;
    min-height: 72px;
    max-height: 84px;
    margin-top: 2px;
    margin-bottom: 2px;
    padding: 6px 12px;
    flex-direction: row;
    align-items: center;
    background-color: rgba(245, 224, 183, 0.10);
    border-left-width: 5px;
    border-left-color: rgb(143, 82, 24);
    border-top-width: 0;
    border-right-width: 0;
    border-bottom-width: 1px;
    border-bottom-color: rgba(95, 58, 27, 0.38);
    border-top-left-radius: 3px;
    border-bottom-left-radius: 3px;
}

.ps-home-entry:hover {
    background-color: rgba(255, 239, 198, 0.46);
    border-left-color: rgb(198, 127, 35);
}

.ps-home-entry-icon {
    width: 48px;
    font-size: 27px;
    -unity-text-align: middle-center;
    color: rgb(117, 67, 21);
}

.ps-home-entry-copy {
    flex-grow: 1;
}

.ps-home-entry-title {
    font-size: 22px;
    margin-bottom: 1px;
}

.ps-home-entry-copy .ps-body {
    font-size: 15px;
    color: rgb(86, 57, 31);
}

.ps-home-entry-arrow {
    width: 32px;
    font-size: 31px;
    -unity-text-align: middle-center;
    color: rgb(117, 67, 21);
}

.ps-book-screen {
    background-color: rgb(49, 34, 23);
}

.ps-book-screen.ps-book-white {
    background-color: rgb(255, 255, 255);
}

.ps-book-background {
    position: absolute;
    left: 4%;
    right: 4%;
    top: 1%;
    bottom: 1%;
}

.ps-book-screen.ps-book-white .ps-book-pages {
    left: 4%;
    right: 4%;
    top: 6%;
    bottom: 6%;
}

.ps-book-screen.ps-book-white .ps-book-page {
    background-color: rgb(255, 255, 255);
    padding-left: 28px;
    padding-right: 28px;
}

.ps-book-heading {
    display: none;
}

.ps-book-pages {
    position: absolute;
    left: 10.7%;
    right: 12.8%;
    top: 9.5%;
    bottom: 8.3%;
    flex-direction: row;
}

.ps-book-page {
    width: 48.6%;
    margin-left: 0.7%;
    margin-right: 0.7%;
    padding: 10px 22px 14px 22px;
    overflow: hidden;
}

.ps-page-left {
    padding-left: 58px;
    padding-right: 30px;
}

.ps-page-right {
    padding-left: 30px;
    padding-right: 42px;
}

.ps-book-page > .ps-title {
    font-size: 25px;
    margin-bottom: 8px;
}

.ps-record-list,
.ps-compendium-scroll {
    flex-grow: 1;
}

.ps-record-button {
    min-height: 102px;
    margin-bottom: 8px;
    padding: 7px 10px;
    flex-direction: row;
    align-items: center;
    background-color: rgba(185, 145, 89, 0.12);
    border-left-width: 4px;
    border-left-color: rgba(105, 62, 23, 0.52);
    border-top-width: 1px;
    border-right-width: 1px;
    border-bottom-width: 1px;
    border-top-color: rgba(105, 62, 23, 0.22);
    border-right-color: rgba(105, 62, 23, 0.22);
    border-bottom-color: rgba(105, 62, 23, 0.22);
    border-top-left-radius: 7px;
    border-top-right-radius: 7px;
    border-bottom-left-radius: 7px;
    border-bottom-right-radius: 7px;
}

.ps-record-button.ps-selected,
.ps-atlas-button.ps-selected,
.ps-button.ps-selected,
.ps-book-tab.ps-selected {
    background-color: rgba(185, 123, 43, 0.33);
    border-left-color: rgb(157, 88, 24);
    border-right-color: rgb(157, 88, 24);
    border-top-color: rgb(157, 88, 24);
    border-bottom-color: rgb(157, 88, 24);
}

.ps-record-thumb {
    width: 82px;
    height: 82px;
    margin-right: 14px;
}

.ps-record-copy {
    flex-grow: 1;
}

.ps-record-copy .ps-title {
    font-size: 20px;
}

.ps-record-copy .ps-body {
    font-size: 16px;
}

.ps-detail-art {
    height: 224px;
    margin: 3px 20px 12px 20px;
    background-color: rgba(90, 55, 23, 0.08);
    border-left-width: 2px;
    border-right-width: 2px;
    border-top-width: 2px;
    border-bottom-width: 2px;
    border-left-color: rgba(107, 65, 25, 0.55);
    border-right-color: rgba(107, 65, 25, 0.55);
    border-top-color: rgba(107, 65, 25, 0.55);
    border-bottom-color: rgba(107, 65, 25, 0.55);
}

.ps-milestones {
    margin-top: 10px;
}

.ps-milestone {
    min-height: 76px;
    margin-bottom: 7px;
    padding: 8px 12px;
    border-left-width: 4px;
    border-left-color: rgb(134, 78, 25);
    background-color: rgba(166, 114, 49, 0.12);
}

.ps-milestone .ps-title {
    font-size: 18px;
}

.ps-milestone .ps-body {
    font-size: 15px;
}

.ps-milestone.ps-locked {
    opacity: 0.38;
}

.ps-category-tabs {
    height: 58px;
    min-height: 58px;
    flex-direction: row;
    flex-shrink: 0;
    margin-bottom: 16px;
}

.ps-category-tabs .ps-button {
    flex-grow: 1;
    min-height: 43px;
    margin-right: 5px;
    font-size: 17px;
}

.ps-compendium-grid {
    flex-direction: row;
    flex-wrap: wrap;
    align-content: flex-start;
}

.ps-atlas-button {
    width: 31.2%;
    height: 154px;
    margin: 1%;
    padding: 5px;
    background-color: rgba(174, 130, 71, 0.10);
    border-left-width: 2px;
    border-right-width: 2px;
    border-top-width: 2px;
    border-bottom-width: 2px;
    border-left-color: rgba(105, 62, 23, 0.38);
    border-right-color: rgba(105, 62, 23, 0.38);
    border-top-color: rgba(105, 62, 23, 0.38);
    border-bottom-color: rgba(105, 62, 23, 0.38);
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
    border-bottom-left-radius: 6px;
    border-bottom-right-radius: 6px;
}

.ps-atlas-image {
    flex-grow: 1;
}

.ps-atlas-label {
    height: 28px;
    font-size: 16px;
    -unity-font-style: bold;
    -unity-text-align: middle-center;
    color: rgb(61, 35, 16);
}

.ps-atlas-button.ps-unknown {
    opacity: 0.28;
}

.ps-book-tabs {
    position: absolute;
    left: auto;
    right: 1.1%;
    top: 12%;
    bottom: auto;
    width: 106px;
    height: 74%;
    flex-direction: column;
    justify-content: flex-start;
}

.ps-book-tab {
    width: 102px;
    min-height: 50px;
    margin-top: 4px;
    margin-bottom: 4px;
    font-size: 15px;
    border-top-left-radius: 10px;
    border-bottom-left-radius: 10px;
    border-top-right-radius: 2px;
    border-bottom-right-radius: 2px;
}

.ps-vault-grid {
    flex-direction: row;
    flex-wrap: wrap;
    align-content: flex-start;
    margin-top: 12px;
}

.ps-vault-grid .ps-atlas-button {
    width: 23%;
    height: 138px;
    margin: 1%;
}

.ps-detail-actions,
.ps-loadout-tabs {
    flex-direction: row;
    margin-top: 14px;
}

.ps-detail-actions .ps-button,
.ps-loadout-tabs .ps-button {
    flex-grow: 1;
    margin-right: 7px;
}

.ps-faction-board {
    flex-grow: 1;
    justify-content: center;
}

.ps-faction-thumb {
    width: 96px;
    height: 82px;
    margin-right: 14px;
}

.ps-expedition-thumb {
    width: 132px;
    height: 92px;
    margin-right: 14px;
}

.ps-progress {
    height: 16px;
    margin-top: 10px;
    margin-bottom: 12px;
    background-color: rgba(78, 46, 21, 0.22);
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(93, 52, 20, 0.65);
    border-right-color: rgba(93, 52, 20, 0.65);
    border-top-color: rgba(93, 52, 20, 0.65);
    border-bottom-color: rgba(93, 52, 20, 0.65);
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
    border-bottom-left-radius: 8px;
    border-bottom-right-radius: 8px;
}

.ps-progress-fill {
    height: 100%;
    background-color: rgb(161, 96, 29);
    border-top-left-radius: 7px;
    border-top-right-radius: 7px;
    border-bottom-left-radius: 7px;
    border-bottom-right-radius: 7px;
}

.ps-primary-action {
    min-height: 66px;
    margin-top: 18px;
    font-size: 21px;
    background-color: rgb(112, 59, 24);
}

.ps-locked {
    opacity: 0.38;
}

.ps-character-preview {
    flex-grow: 1;
    min-height: 470px;
    margin: 8px 16px 10px 16px;
    background-color: rgba(0, 0, 0, 0);
    border-left-width: 0;
    border-right-width: 0;
    border-top-width: 0;
    border-bottom-width: 0;
}

.ps-choice-grid,
.ps-choice-row,
.ps-packing-inventory,
.ps-bag-tabs,
.ps-packing-tools {
    flex-direction: row;
    flex-wrap: wrap;
}

.ps-choice-grid .ps-atlas-button {
    width: 48%;
    height: 165px;
}

.ps-choice-row .ps-atlas-button {
    width: 31%;
    height: 145px;
}

.ps-bag-tabs .ps-button {
    min-height: 40px;
    font-size: 14px;
    margin: 2px;
    flex-grow: 1;
}

.ps-packing-tools .ps-button {
    width: 31.5%;
    min-width: 0;
    flex-grow: 0;
    margin: 6px 3px;
    padding-left: 5px;
    padding-right: 5px;
    font-size: 14px;
}

.ps-packing-tools {
    flex-wrap: nowrap;
}

.ps-backpack-grid {
    height: 338px;
    min-height: 338px;
    flex-shrink: 0;
    flex-direction: row;
    flex-wrap: wrap;
    padding: 13px;
    margin-top: 6px;
    background-color: rgb(54, 36, 24);
    border-left-width: 7px;
    border-right-width: 7px;
    border-top-width: 7px;
    border-bottom-width: 7px;
    border-left-color: rgb(112, 72, 32);
    border-right-color: rgb(112, 72, 32);
    border-top-color: rgb(112, 72, 32);
    border-bottom-color: rgb(112, 72, 32);
    border-top-left-radius: 18px;
    border-top-right-radius: 18px;
    border-bottom-left-radius: 18px;
    border-bottom-right-radius: 18px;
}

.ps-backpack-cell {
    width: 16.1%;
    height: 74px;
    margin: 0.27%;
    padding: 6px;
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(227, 203, 153, 0.23);
    border-right-color: rgba(227, 203, 153, 0.23);
    border-top-color: rgba(227, 203, 153, 0.23);
    border-bottom-color: rgba(227, 203, 153, 0.23);
    border-top-left-radius: 5px;
    border-top-right-radius: 5px;
    border-bottom-left-radius: 5px;
    border-bottom-right-radius: 5px;
}

.ps-element-fire { background-color: rgb(83, 48, 42); }
.ps-element-water { background-color: rgb(42, 60, 72); }
.ps-element-wind { background-color: rgb(47, 70, 59); }
.ps-element-earth { background-color: rgb(72, 63, 43); }
.ps-cell-item { flex-grow: 1; }

.ps-packing-inventory .ps-atlas-button {
    width: 23%;
    height: 126px;
    margin: 1%;
}

.ps-card-choice-list .ps-card {
    min-height: 72px;
    margin: 3px 0;
    padding: 9px 12px;
}

.ps-card-choice-list .ps-title { font-size: 17px; }
.ps-card-choice-list .ps-body { font-size: 14px; }

.ps-event-screen,
.ps-event-background,
.ps-event-mist {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
}

.ps-event-mist {
    align-items: center;
    justify-content: center;
    background-color: rgba(8, 6, 10, 0.72);
}

.ps-event-panel {
    width: 66%;
    max-width: 980px;
    padding: 30px 36px;
    background-color: rgba(25, 20, 22, 0.96);
    border-left-width: 3px;
    border-right-width: 3px;
    border-top-width: 3px;
    border-bottom-width: 3px;
    border-left-color: rgb(150, 105, 48);
    border-right-color: rgb(150, 105, 48);
    border-top-color: rgb(150, 105, 48);
    border-bottom-color: rgb(150, 105, 48);
    border-top-left-radius: 14px;
    border-top-right-radius: 14px;
    border-bottom-left-radius: 14px;
    border-bottom-right-radius: 14px;
}

.ps-event-panel .ps-title { color: rgb(246, 211, 139); }
.ps-event-panel > .ps-body { color: rgb(221, 209, 184); margin-bottom: 16px; }
.ps-event-choice { background-color: rgba(78, 58, 43, 0.96); }
.ps-event-choice .ps-title, .ps-event-choice .ps-body { color: rgb(242, 222, 180); }

.ps-result-art {
    height: 390px;
    margin: 8px 10px 18px 10px;
    border-left-width: 3px;
    border-right-width: 3px;
    border-top-width: 3px;
    border-bottom-width: 3px;
    border-left-color: rgb(117, 72, 27);
    border-right-color: rgb(117, 72, 27);
    border-top-color: rgb(117, 72, 27);
    border-bottom-color: rgb(117, 72, 27);
}

.ps-result-row {
    min-height: 70px;
    margin: 5px 0;
    padding: 9px 16px;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    background-color: rgba(174, 129, 66, 0.12);
    border-bottom-width: 1px;
    border-bottom-color: rgba(98, 58, 24, 0.48);
}

.transition-dim,
.transition-paper,
.transition-scroll,
.transition-battle {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
}

.transition-dim {
    background-color: rgba(10, 7, 4, 0.82);
}

.transition-paper {
    width: 50%;
    background-color: rgb(213, 187, 140);
    border-top-width: 5px;
    border-bottom-width: 5px;
    border-top-color: rgb(91, 55, 24);
    border-bottom-color: rgb(91, 55, 24);
}

.transition-paper-left {
    left: 0;
    border-right-width: 2px;
    border-right-color: rgba(62, 35, 15, 0.75);
}

.transition-paper-right {
    left: 50%;
    border-left-width: 2px;
    border-left-color: rgba(255, 234, 183, 0.45);
}

.transition-scroll {
    left: 6%;
    top: 9%;
    width: 88%;
    height: 82%;
    background-color: rgb(204, 175, 125);
    border-left-width: 9px;
    border-right-width: 9px;
    border-top-width: 3px;
    border-bottom-width: 3px;
    border-left-color: rgb(75, 43, 19);
    border-right-color: rgb(75, 43, 19);
    border-top-color: rgb(119, 76, 34);
    border-bottom-color: rgb(119, 76, 34);
    border-top-left-radius: 12px;
    border-top-right-radius: 12px;
    border-bottom-left-radius: 12px;
    border-bottom-right-radius: 12px;
}

.transition-battle {
    background-color: rgb(35, 16, 12);
    border-left-width: 12px;
    border-right-width: 12px;
    border-left-color: rgb(150, 99, 35);
    border-right-color: rgb(150, 99, 35);
}

.ps-title {
    font-size: 32px;
    -unity-font-style: bold;
    color: rgb(70, 37, 15);
}

.ps-body {
    font-size: 19px;
    white-space: normal;
    color: rgb(63, 43, 25);
}

.ps-button {
    min-height: 52px;
    padding-left: 18px;
    padding-right: 18px;
    font-size: 19px;
    -unity-font-style: bold;
    background-color: rgba(87, 57, 28, 0.94);
    color: rgb(250, 232, 189);
    border-left-width: 2px;
    border-right-width: 2px;
    border-top-width: 2px;
    border-bottom-width: 2px;
    border-left-color: rgb(178, 125, 49);
    border-right-color: rgb(178, 125, 49);
    border-top-color: rgb(178, 125, 49);
    border-bottom-color: rgb(178, 125, 49);
    border-top-left-radius: 7px;
    border-top-right-radius: 7px;
    border-bottom-left-radius: 7px;
    border-bottom-right-radius: 7px;
}

.ps-card {
    padding: 16px;
    margin: 6px;
    background-color: rgba(225, 202, 159, 0.94);
    border-left-width: 2px;
    border-right-width: 2px;
    border-top-width: 2px;
    border-bottom-width: 2px;
    border-left-color: rgb(111, 72, 30);
    border-right-color: rgb(111, 72, 30);
    border-top-color: rgb(111, 72, 30);
    border-bottom-color: rgb(111, 72, 30);
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
    border-bottom-left-radius: 8px;
    border-bottom-right-radius: 8px;
}

.ps-empty-state {
    min-height: 180px;
    align-items: center;
    justify-content: center;
    opacity: 0.82;
}

.ps-dialog {
    position: absolute;
    left: 25%;
    right: 25%;
    top: 24%;
    min-height: 280px;
    padding: 28px;
    background-color: rgb(218, 194, 150);
    border-left-width: 4px;
    border-right-width: 4px;
    border-top-width: 4px;
    border-bottom-width: 4px;
    border-left-color: rgb(89, 54, 23);
    border-right-color: rgb(89, 54, 23);
    border-top-color: rgb(89, 54, 23);
    border-bottom-color: rgb(89, 54, 23);
    border-top-left-radius: 12px;
    border-top-right-radius: 12px;
    border-bottom-left-radius: 12px;
    border-bottom-right-radius: 12px;
}

.ps-dialog-actions {
    margin-top: 24px;
    flex-direction: row;
    justify-content: flex-end;
}

.ps-dialog-actions > .ps-button {
    min-width: 160px;
    margin-left: 12px;
}

/* Product polish layer: shared art direction and interaction feedback. */
.ps-page-heading {
    height: 52px;
    min-height: 52px;
    margin-bottom: 14px;
    padding-bottom: 6px;
    flex-direction: row;
    align-items: center;
    border-bottom-width: 2px;
    border-bottom-color: rgba(104, 58, 22, 0.52);
}

.ps-page-heading-mark {
    width: 30px;
    margin-right: 8px;
    font-size: 18px;
    -unity-text-align: middle-center;
    color: rgb(151, 82, 25);
}

.ps-page-heading-title {
    flex-grow: 1;
    font-size: 27px;
    -unity-font-style: bold;
    color: rgb(73, 38, 15);
}

.ps-home-entry {
    background-color: rgba(255, 255, 255, 0);
    background-image: resource("Art/UI/HomeBars/home-bar-secondary-v1");
    -unity-background-scale-mode: stretch-to-fill;
    -unity-background-image-tint-color: rgb(226, 213, 181);
    border-left-width: 0;
    border-right-width: 0;
    border-top-width: 0;
    border-bottom-width: 0;
    transition-property: translate, -unity-background-image-tint-color;
    transition-duration: 0.12s;
}

.ps-home-entry:hover {
    -unity-background-image-tint-color: rgb(255, 245, 207);
    translate: -6px 0;
}

.ps-home-entry-icon-image {
    width: 58px;
    height: 58px;
    margin-left: 8px;
    margin-right: 12px;
    -unity-background-image-tint-color: rgb(239, 205, 126);
}

.ps-home-entry-title { color: rgb(244, 226, 184); }
.ps-home-entry-copy .ps-body { color: rgb(191, 181, 155); }
.ps-home-entry-arrow { color: rgb(222, 176, 82); }

.ps-record-button,
.ps-atlas-button,
.ps-button {
    transition-property: translate, background-color, border-left-color, border-right-color, border-top-color, border-bottom-color;
    transition-duration: 0.10s;
}

.ps-record-button:hover {
    translate: 5px 0;
    background-color: rgba(218, 174, 106, 0.22);
    border-left-color: rgb(163, 90, 24);
}

.ps-atlas-button:hover {
    translate: 0 -4px;
    background-color: rgba(202, 154, 82, 0.22);
    border-left-color: rgb(156, 87, 25);
    border-right-color: rgb(156, 87, 25);
    border-top-color: rgb(156, 87, 25);
    border-bottom-color: rgb(156, 87, 25);
}

.ps-button:hover {
    translate: 0 -2px;
    background-color: rgb(111, 72, 31);
    border-left-color: rgb(221, 166, 73);
    border-right-color: rgb(221, 166, 73);
    border-top-color: rgb(221, 166, 73);
    border-bottom-color: rgb(221, 166, 73);
}

.ps-button:active { translate: 0 1px; }

.ps-book-tab {
    padding: 4px 7px 4px 4px;
    flex-direction: row;
    align-items: center;
    background-color: rgba(255, 255, 255, 0);
    background-image: resource("Art/UI/Buttons/ui-card-14");
    -unity-background-scale-mode: stretch-to-fill;
    -unity-background-image-tint-color: rgb(210, 198, 172);
    border-left-width: 0;
    border-right-width: 0;
    border-top-width: 0;
    border-bottom-width: 0;
    transition-property: translate, -unity-background-image-tint-color;
    transition-duration: 0.12s;
}

.ps-book-tab:hover {
    translate: -7px 0;
    -unity-background-image-tint-color: rgb(255, 238, 191);
}

.ps-book-tab.ps-selected {
    translate: -9px 0;
    -unity-background-image-tint-color: rgb(255, 218, 130);
}

.ps-book-tab-icon {
    width: 34px;
    height: 34px;
    margin-right: 3px;
}

.ps-book-tab-label {
    flex-grow: 1;
    font-size: 14px;
    -unity-font-style: bold;
    -unity-text-align: middle-left;
    color: rgb(245, 226, 181);
}

.ps-primary-action {
    padding-left: 56px;
    padding-right: 34px;
    background-color: rgba(255, 255, 255, 0);
    background-image: resource("Art/UI/HomeBars/home-bar-primary-v1");
    -unity-background-scale-mode: stretch-to-fill;
    -unity-background-image-tint-color: rgb(241, 226, 195);
    color: rgb(250, 232, 188);
    border-left-width: 0;
    border-right-width: 0;
    border-top-width: 0;
    border-bottom-width: 0;
}

.ps-primary-action:hover {
    -unity-background-image-tint-color: rgb(255, 245, 212);
    color: rgb(255, 242, 201);
}

.ps-record-button,
.ps-atlas-button {
    position: relative;
}

.ps-selection-badge {
    position: absolute;
    right: 7px;
    top: 7px;
    min-width: 64px;
    height: 25px;
    padding-left: 8px;
    padding-right: 8px;
    font-size: 12px;
    -unity-font-style: bold;
    -unity-text-align: middle-center;
    color: rgb(255, 235, 184);
    background-color: rgb(111, 55, 20);
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgb(205, 147, 55);
    border-right-color: rgb(205, 147, 55);
    border-top-color: rgb(205, 147, 55);
    border-bottom-color: rgb(205, 147, 55);
    border-top-left-radius: 12px;
    border-top-right-radius: 12px;
    border-bottom-left-radius: 12px;
    border-bottom-right-radius: 12px;
}

.ps-selected {
    border-left-color: rgb(177, 96, 24);
    border-right-color: rgb(177, 96, 24);
    border-top-color: rgb(177, 96, 24);
    border-bottom-color: rgb(177, 96, 24);
}

.ps-locked,
.ps-unknown {
    -unity-background-image-tint-color: rgb(128, 119, 103);
}

.ps-title,
.ps-page-heading-title,
.ps-home-entry-title,
.ps-book-tab-label {
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
}

.ps-card {
    transition-property: translate, background-color, border-left-color, border-right-color, border-top-color, border-bottom-color;
    transition-duration: 0.10s;
}

.ps-card:hover {
    translate: 0 -2px;
    background-color: rgb(235, 211, 165);
    border-left-color: rgb(174, 101, 28);
    border-right-color: rgb(174, 101, 28);
    border-top-color: rgb(174, 101, 28);
    border-bottom-color: rgb(174, 101, 28);
}

.ps-backpack-cell {
    position: relative;
    transition-property: translate, border-left-color, border-right-color, border-top-color, border-bottom-color;
    transition-duration: 0.08s;
}

.ps-backpack-cell:hover {
    translate: 0 -2px;
    border-left-color: rgb(211, 169, 85);
    border-right-color: rgb(211, 169, 85);
    border-top-color: rgb(211, 169, 85);
    border-bottom-color: rgb(211, 169, 85);
}

.ps-cell-match {
    border-left-width: 3px;
    border-right-width: 3px;
    border-top-width: 3px;
    border-bottom-width: 3px;
    border-left-color: rgb(222, 177, 67);
    border-right-color: rgb(222, 177, 67);
    border-top-color: rgb(222, 177, 67);
    border-bottom-color: rgb(222, 177, 67);
}

.ps-cell-mismatch {
    -unity-background-image-tint-color: rgb(177, 168, 147);
}

.ps-cell-selected {
    border-left-color: rgb(255, 230, 138);
    border-right-color: rgb(255, 230, 138);
    border-top-color: rgb(255, 230, 138);
    border-bottom-color: rgb(255, 230, 138);
}

.ps-match-mark {
    position: absolute;
    right: 4px;
    top: 2px;
    width: 20px;
    height: 20px;
    font-size: 13px;
    -unity-font-style: bold;
    -unity-text-align: middle-center;
    color: rgb(255, 223, 115);
    background-color: rgba(69, 39, 16, 0.82);
    border-top-left-radius: 10px;
    border-top-right-radius: 10px;
    border-bottom-left-radius: 10px;
    border-bottom-right-radius: 10px;
}

.ps-toast {
    position: absolute;
    right: 5%;
    top: 5%;
    min-width: 300px;
    min-height: 54px;
    padding: 12px 24px;
    align-items: center;
    justify-content: center;
    background-color: rgba(34, 27, 20, 0.96);
    background-image: resource("Art/UI/HomeBars/home-bar-secondary-v1");
    -unity-background-scale-mode: stretch-to-fill;
    border-left-width: 0;
    border-right-width: 0;
    border-top-width: 0;
    border-bottom-width: 0;
    transition-property: opacity, translate;
    transition-duration: 0.18s;
}

.ps-toast Label {
    padding-left: 34px;
    padding-right: 18px;
    font-size: 17px;
    -unity-font-style: bold;
    -unity-text-align: middle-center;
    color: rgb(250, 229, 182);
}

/* Field journal layer: paper, ink, ruled lines and restrained bookmarks. */
.ps-home-entry { min-height:72px; padding:7px 12px 7px 5px; margin-top:1px; margin-bottom:1px; background-color:rgba(104,68,34,0.025); background-image:none; border-left-width:0; border-right-width:0; border-top-width:0; border-bottom-width:0; border-top-left-radius:0; border-top-right-radius:0; border-bottom-left-radius:0; border-bottom-right-radius:0; translate:0 0; transition-property:background-color; transition-duration:0.10s; }
.ps-home-entry:hover { translate:0 0; background-color:rgba(132,77,28,0.10); border-bottom-color:rgb(91,48,24); }
.ps-home-entry-margin-mark { width:4px; height:46px; margin-left:3px; margin-right:14px; background-color:rgb(126,47,38); opacity:0.78; }
.ps-home-entry-icon-image { display:none; }
.ps-home-entry-title { color:rgb(62,38,23); font-size:27px; -unity-font-style:bold; }
.ps-home-entry-copy .ps-body { color:rgb(91,63,40); opacity:1; }
.ps-home-entry-arrow { color:rgb(100,76,53); }

.ps-page-heading { min-height:58px; margin-bottom:14px; padding-left:2px; padding-bottom:7px; border-bottom-width:0; }
.ps-page-heading-mark { display:none; }
.ps-page-heading-title { color:rgb(59,35,20); font-size:39px; -unity-font-style:bold; }

.ps-book-tab { width:92px; min-width:92px; height:47px; min-height:47px; padding:4px 10px; margin-top:3px; margin-bottom:3px; background-image:none; background-color:rgb(91,64,43); border-left-width:1px; border-right-width:0; border-top-width:1px; border-bottom-width:1px; border-left-color:rgb(57,38,27); border-top-color:rgb(57,38,27); border-bottom-color:rgb(57,38,27); border-top-left-radius:2px; border-bottom-left-radius:2px; border-top-right-radius:0; border-bottom-right-radius:0; translate:0 0; opacity:0.88; transition-property:background-color,opacity; transition-duration:0.10s; }
.ps-book-tab:hover { translate:0 0; background-color:rgb(107,72,45); opacity:1; }
.ps-book-tab.ps-selected { translate:0 0; background-color:rgb(112,48,38); opacity:1; }
.ps-book-tab-icon { display:none; }
.ps-book-tab-label { margin-left:0; color:rgb(236,220,181); font-size:15px; -unity-text-align:middle-center; }

.ps-button { background-image:none; background-color:rgba(119,75,35,0.08); color:rgb(67,42,25); border-left-width:1px; border-right-width:1px; border-top-width:1px; border-bottom-width:1px; border-left-color:rgba(101,62,29,0.58); border-right-color:rgba(101,62,29,0.58); border-top-color:rgba(101,62,29,0.58); border-bottom-color:rgba(101,62,29,0.58); border-top-left-radius:2px; border-top-right-radius:2px; border-bottom-left-radius:2px; border-bottom-right-radius:2px; translate:0 0; transition-property:background-color,border-left-color,border-right-color,border-top-color,border-bottom-color; transition-duration:0.08s; }
.ps-button:hover { translate:0 0; background-color:rgba(132,75,28,0.16); color:rgb(55,31,18); border-left-color:rgb(112,61,26); border-right-color:rgb(112,61,26); border-top-color:rgb(112,61,26); border-bottom-color:rgb(112,61,26); }
.ps-button:active { translate:0 0; }

.ps-primary-action { padding-left:24px; padding-right:24px; background-image:none; background-color:rgba(112,63,25,0.10); color:rgb(63,36,20); border-left-width:2px; border-right-width:2px; border-top-width:2px; border-bottom-width:3px; border-left-color:rgb(91,52,25); border-right-color:rgb(91,52,25); border-top-color:rgb(91,52,25); border-bottom-color:rgb(91,52,25); border-top-left-radius:2px; border-top-right-radius:2px; border-bottom-left-radius:2px; border-bottom-right-radius:2px; }
.ps-primary-action:hover { background-color:rgba(126,55,36,0.14); color:rgb(61,29,20); }

.ps-category-tabs .ps-button { position:relative; background-color:rgba(255,255,255,0); border-left-width:0; border-right-width:0; border-top-width:0; border-bottom-width:0; border-top-left-radius:0; border-top-right-radius:0; border-bottom-left-radius:0; border-bottom-right-radius:0; }
.ps-category-tabs .ps-button.ps-selected { color:rgb(113,43,34); background-color:rgba(255,255,255,0); }
.ps-category-tabs .ps-button.ps-selected .ps-ink-rule { -unity-background-image-tint-color:rgba(126,45,36,0.92); }

.ps-selection-badge { right:8px; top:5px; min-width:0; height:22px; padding-left:4px; padding-right:4px; color:rgb(127,45,36); background-color:rgba(255,255,255,0); border-left-width:0; border-right-width:0; border-top-width:0; border-bottom-width:1px; border-bottom-color:rgb(127,45,36); border-top-left-radius:0; border-top-right-radius:0; border-bottom-left-radius:0; border-bottom-right-radius:0; -unity-font-style:bold-and-italic; }

.ps-record-button,.ps-atlas-button,.ps-card,.ps-backpack-cell { translate:0 0; }
.ps-record-button:hover,.ps-atlas-button:hover,.ps-card:hover,.ps-backpack-cell:hover { translate:0 0; }
.ps-card:hover { background-color:rgba(151,100,48,0.10); border-left-color:rgb(135,81,34); border-right-color:rgb(135,81,34); border-top-color:rgb(135,81,34); border-bottom-color:rgb(135,81,34); }

.ps-toast { min-width:320px; padding:13px 24px; background-image:none; background-color:rgb(218,195,151); border-left-width:1px; border-right-width:1px; border-top-width:1px; border-bottom-width:2px; border-left-color:rgb(89,54,29); border-right-color:rgb(89,54,29); border-top-color:rgb(89,54,29); border-bottom-color:rgb(89,54,29); }
.ps-toast Label { padding-left:0; padding-right:0; color:rgb(59,35,21); }

.ps-ink-rule {
    position: absolute;
    left: 0;
    right: 0;
    bottom: -8px;
    height: 17px;
    background-image: resource("Art/UI/ink-divider-v2");
    -unity-background-scale-mode: stretch-to-fill;
    -unity-background-image-tint-color: rgba(86, 47, 26, 0.72);
}

.ps-home-entry .ps-ink-rule,
.ps-record-button .ps-ink-rule {
    bottom: -6px;
    height: 13px;
    opacity: 0.82;
}

.ps-category-tabs .ps-ink-rule {
    bottom: -5px;
    height: 11px;
}

.ps-index-heading {
    position: relative;
    border-bottom-width: 0;
}

.ps-record-button {
    position: relative;
    border-bottom-width: 0;
}

/* Typography: display lettering for headings, handwritten field notes below. */
.ps-body,
.ps-home-entry-copy .ps-body,
.ps-record-copy .ps-body,
.ps-milestone .ps-body,
.ps-event-panel > .ps-body,
.ps-card-choice-list .ps-body {
    -unity-font-definition: resource("Fonts/KleeOne-Regular");
}

.ps-button,
.ps-atlas-label,
.ps-book-tab-label,
.ps-selection-badge,
.ps-match-mark {
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
}

/* Packing page: reserve a real row for every control group. */
.ps-packing-page .ps-loadout-tabs {
    height: 56px;
    min-height: 56px;
    margin-top: 0;
    margin-bottom: 8px;
    flex-shrink: 0;
    flex-wrap: nowrap;
}

.ps-packing-page .ps-loadout-tabs .ps-button {
    height: 50px;
    min-height: 50px;
    margin-right: 6px;
    padding-left: 8px;
    padding-right: 8px;
    font-size: 17px;
}

.ps-packing-page .ps-bag-tabs {
    height: 96px;
    min-height: 96px;
    margin-bottom: 8px;
    flex-shrink: 0;
    align-content: flex-start;
}

.ps-packing-page .ps-bag-tabs .ps-button {
    width: 48%;
    height: 43px;
    min-height: 43px;
    margin: 2px 1%;
    padding-left: 7px;
    padding-right: 7px;
    flex-grow: 0;
    font-size: 15px;
}

.ps-packing-page .ps-packing-tools {
    height: 54px;
    min-height: 54px;
    margin-bottom: 7px;
    flex-shrink: 0;
}

.ps-packing-page .ps-packing-tools .ps-button {
    width: 32%;
    height: 48px;
    min-height: 48px;
    margin: 2px 0.65%;
    font-size: 15px;
}

.ps-packing-hint {
    height: 54px;
    min-height: 54px;
    margin-top: 0;
    margin-bottom: 8px;
    flex-shrink: 0;
    font-size: 16px;
    color: rgb(83, 58, 38);
}

.ps-packing-page .ps-backpack-grid {
    margin-top: 0;
}

/* Tabletop world: one continuous desk, with independent props and camera-ready workspaces. */
.ps-tabletop-desk {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    overflow: hidden;
    background-color: rgb(48, 25, 13);
}

.ps-tabletop-desk-art {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    width: 100%;
    height: 100%;
}

.ps-tabletop-book {
    position: absolute;
    left: 20%;
    top: 7%;
    width: 61%;
    height: 86%;
    transition-property: translate, scale;
    transition-duration: 0.22s;
}

.ps-tabletop-book-art,
.ps-detail-journal-art {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    width: 100%;
    height: 100%;
}

.ps-tabletop-page {
    position: absolute;
    top: 13%;
    bottom: 12%;
    padding: 16px 22px;
    overflow: hidden;
}

.ps-tabletop-page-left { left: 10%; width: 38%; }
.ps-tabletop-page-right { left: 52%; width: 38%; }
.ps-tabletop-page > .ps-title { font-size: 30px; }
.ps-tabletop-page > .ps-body { font-size: 17px; }

.ps-tabletop-character {
    height: 58%;
    margin: 3px 4% 5px 4%;
}

.ps-journal-link {
    height: 68px;
    margin-top: 7px;
    padding: 8px 12px;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    color: rgb(60, 37, 22);
    font-size: 22px;
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
    background-color: rgba(113, 68, 30, 0.05);
    border-left-width: 3px;
    border-left-color: rgba(125, 48, 38, 0.72);
    border-right-width: 0;
    border-top-width: 0;
    border-bottom-width: 1px;
    border-bottom-color: rgba(92, 55, 29, 0.48);
    transition-property: translate, background-color;
    transition-duration: 0.12s;
}
.ps-journal-link:hover { translate: 7px 0; background-color: rgba(139, 81, 31, 0.13); }

.ps-edge-object {
    position: absolute;
    color: rgb(246, 226, 179);
    background-color: rgb(84, 48, 25);
    border-left-width: 3px;
    border-right-width: 3px;
    border-top-width: 3px;
    border-bottom-width: 3px;
    border-left-color: rgb(145, 93, 38);
    border-right-color: rgb(145, 93, 38);
    border-top-color: rgb(145, 93, 38);
    border-bottom-color: rgb(145, 93, 38);
    transition-property: translate, background-color;
    transition-duration: 0.20s;
}

.ps-edge-label {
    font-size: 20px;
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
    -unity-text-align: middle-center;
    color: rgb(247, 225, 177);
}

.ps-edge-corkboard { left: -8%; top: 5%; width: 20%; height: 30%; background-color: rgb(113, 65, 27); }
.ps-edge-corkboard:hover { translate: 48% 0; background-color: rgb(137, 81, 33); }
.ps-edge-expedition { right: -9%; top: 7%; width: 21%; height: 28%; background-color: rgb(61, 38, 25); }
.ps-edge-expedition:hover { translate: -48% 0; background-color: rgb(82, 51, 30); }
.ps-edge-packing { right: -9%; bottom: 5%; width: 23%; height: 26%; background-color: rgb(88, 78, 43); }
.ps-edge-packing:hover { translate: -42% 0; background-color: rgb(109, 96, 50); }

.ps-tabletop-back {
    position: absolute;
    left: 24px;
    bottom: 22px;
    width: 190px;
    height: 48px;
    font-size: 16px;
    color: rgb(241, 221, 177);
    background-color: rgba(54, 31, 18, 0.90);
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgb(146, 98, 50);
    border-right-color: rgb(146, 98, 50);
    border-top-color: rgb(146, 98, 50);
    border-bottom-color: rgb(146, 98, 50);
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
}

.ps-expanded-corkboard {
    position: absolute;
    left: 3%;
    top: 4%;
    width: 64%;
    height: 88%;
    padding: 30px 38px;
    background-color: rgb(143, 91, 43);
    border-left-width: 16px;
    border-right-width: 16px;
    border-top-width: 16px;
    border-bottom-width: 16px;
    border-left-color: rgb(74, 39, 19);
    border-right-color: rgb(74, 39, 19);
    border-top-color: rgb(74, 39, 19);
    border-bottom-color: rgb(74, 39, 19);
}
.ps-expanded-corkboard > .ps-title, .ps-expanded-corkboard > .ps-body { color: rgb(247, 226, 183); }
.ps-faction-nodes { position: relative; flex-grow: 1; }
.ps-faction-pin { position: absolute; width: 190px; height: 150px; padding: 8px; background-color: rgb(215, 187, 133); border-left-width: 2px; border-right-width: 2px; border-top-width: 2px; border-bottom-width: 2px; border-left-color: rgb(82, 45, 22); border-right-color: rgb(82, 45, 22); border-top-color: rgb(82, 45, 22); border-bottom-color: rgb(82, 45, 22); }
.ps-faction-pin-0 { left: 8%; top: 8%; }
.ps-faction-pin-1 { right: 8%; top: 12%; }
.ps-faction-pin-2 { left: 35%; bottom: 8%; }
.ps-faction-pin-3 { right: 2%; bottom: 2%; }
.ps-faction-pin-art { height: 82px; }
.ps-faction-pin .ps-title { font-size: 18px; }
.ps-faction-pin .ps-body { font-size: 13px; }
.ps-request-rail { position: absolute; left: 7%; right: 7%; bottom: -54px; height: 58px; padding: 14px; background-color: rgb(72, 42, 22); }
.ps-request-rail .ps-body { color: rgb(231, 208, 162); }

.ps-detail-journal {
    position: absolute;
    right: 1%;
    bottom: 2%;
    width: 38%;
    height: 55%;
}
.ps-detail-journal-copy { position: absolute; left: 12%; right: 11%; top: 14%; bottom: 13%; padding-left: 49%; }
.ps-faction-detail-art { position: absolute; left: 0; top: 0; width: 45%; height: 64%; }
.ps-detail-journal-copy .ps-title { font-size: 23px; }
.ps-detail-journal-copy .ps-body { font-size: 14px; }

.ps-expedition-case {
    position: absolute;
    left: 4%;
    top: 7%;
    width: 70%;
    height: 85%;
    padding: 28px 32px;
    background-color: rgba(43, 27, 19, 0.96);
    border-left-width: 12px;
    border-right-width: 12px;
    border-top-width: 12px;
    border-bottom-width: 12px;
    border-left-color: rgb(104, 64, 34);
    border-right-color: rgb(104, 64, 34);
    border-top-color: rgb(104, 64, 34);
    border-bottom-color: rgb(104, 64, 34);
}
.ps-expedition-case .ps-title, .ps-expedition-case .ps-body { color: rgb(235, 215, 175); }
.ps-expedition-selected-art { height: 37%; margin-bottom: 8px; }
.ps-map-roll-rack { position: absolute; right: 2%; top: 5%; width: 24%; height: 90%; padding: 12px; background-color: rgba(53, 31, 17, 0.94); border-left-width: 7px; border-right-width: 7px; border-top-width: 7px; border-bottom-width: 7px; border-left-color: rgb(115, 69, 32); border-right-color: rgb(115, 69, 32); border-top-color: rgb(115, 69, 32); border-bottom-color: rgb(115, 69, 32); }
.ps-map-roll { height: 102px; min-height: 102px; margin: 5px; padding: 8px 12px; flex-direction: row; align-items: center; font-size: 17px; color: rgb(71, 43, 24); background-color: rgb(211, 183, 130); border-left-width: 8px; border-right-width: 8px; border-left-color: rgb(95, 58, 30); border-right-color: rgb(95, 58, 30); border-top-width: 1px; border-bottom-width: 1px; border-top-color: rgb(126, 83, 41); border-bottom-color: rgb(126, 83, 41); -unity-font-definition: resource("Fonts/KleeOne-SemiBold"); }
.ps-map-roll-seal { width: 76px; height: 76px; margin-right: 10px; }

.ps-canvas-packing-mat {
    position: absolute;
    left: 3%;
    top: 4%;
    width: 63%;
    height: 92%;
    padding: 26px 36px;
    background-color: rgb(89, 83, 54);
    border-left-width: 18px;
    border-right-width: 18px;
    border-top-width: 5px;
    border-bottom-width: 5px;
    border-left-color: rgb(62, 42, 25);
    border-right-color: rgb(62, 42, 25);
    border-top-color: rgb(124, 103, 57);
    border-bottom-color: rgb(124, 103, 57);
}
.ps-canvas-packing-mat > .ps-title, .ps-canvas-packing-mat > .ps-body { color: rgb(241, 225, 184); }
.ps-canvas-packing-mat .ps-button { color: rgb(241, 225, 184); border-left-color: rgba(225, 194, 126, 0.62); border-right-color: rgba(225, 194, 126, 0.62); border-top-color: rgba(225, 194, 126, 0.62); border-bottom-color: rgba(225, 194, 126, 0.62); }
.ps-canvas-packing-mat .ps-backpack-grid { width: 100%; flex-grow: 1; }
.ps-equipment-tray { position: absolute; right: 2%; top: 4%; width: 31%; height: 92%; padding: 20px; background-color: rgba(54, 32, 20, 0.96); border-left-width: 10px; border-right-width: 10px; border-top-width: 10px; border-bottom-width: 10px; border-left-color: rgb(111, 69, 34); border-right-color: rgb(111, 69, 34); border-top-color: rgb(111, 69, 34); border-bottom-color: rgb(111, 69, 34); }
.ps-equipment-tray .ps-title, .ps-equipment-tray .ps-body { color: rgb(237, 216, 173); }
.ps-equipment-tray .ps-atlas-label { color: rgb(235, 216, 174); }

/* Simple hub home (character left, menu right) */
.ps-hub-home {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    padding: 20px 24px;
    background-color: rgb(92, 68, 44);
}

.ps-hub-home-row {
    flex-direction: row;
    flex-grow: 1;
    height: 100%;
    min-height: 0;
    align-items: stretch;
}

.ps-hub-home-stage {
    flex-grow: 1;
    flex-shrink: 1;
    min-width: 0;
    align-items: center;
    justify-content: center;
}

.ps-hub-home-character {
    width: 92%;
    max-width: 540px;
    height: 96%;
    align-items: center;
    justify-content: center;
}

.ps-hub-home-char-layer {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
}

.ps-hub-home-char-far { opacity: 0.72; }
.ps-hub-home-char-mid { opacity: 0.92; }
.ps-hub-home-char-near { opacity: 1; }
.ps-hub-home-char-front { opacity: 1; }

.ps-hub-home-menu {
    width: 280px;
    min-width: 240px;
    max-width: 320px;
    flex-shrink: 0;
    flex-direction: column;
    padding: 20px 18px;
    background-color: rgba(54, 38, 24, 0.92);
    border-left-width: 2px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgb(160, 118, 72);
    border-right-color: rgba(120, 88, 52, 0.7);
    border-top-color: rgba(120, 88, 52, 0.7);
    border-bottom-color: rgba(120, 88, 52, 0.7);
}

.ps-hub-home-title {
    font-size: 28px;
    color: rgb(255, 236, 196);
    margin-bottom: 8px;
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
}

.ps-hub-home-meta {
    font-size: 13px;
    color: rgb(220, 200, 164);
    margin-bottom: 4px;
    white-space: normal;
}

.ps-hub-home-btn {
    height: 46px;
    min-height: 46px;
    margin-top: 10px;
    margin-bottom: 0;
    padding-left: 14px;
    padding-right: 14px;
    font-size: 16px;
    letter-spacing: 1px;
    -unity-text-align: middle-left;
    background-color: rgba(72, 52, 34, 0.96);
    color: rgb(255, 236, 196);
    border-left-width: 3px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgb(210, 168, 96);
    border-right-color: rgba(150, 110, 68, 0.65);
    border-top-color: rgba(150, 110, 68, 0.65);
    border-bottom-color: rgba(150, 110, 68, 0.65);
}

.ps-hub-home-btn:hover {
    background-color: rgba(96, 68, 40, 0.98);
    color: rgb(255, 244, 214);
    border-left-color: rgb(240, 204, 120);
}

.ps-hub-home-menu > .ps-hub-home-btn:first-of-type {
    margin-top: 18px;
}

/* 2.5D hub presentation layer (legacy) */
.ps-v2-home {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    background-color: rgb(20, 26, 34);
    overflow: hidden;
}

.ps-v2-stage-view {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    overflow: hidden;
    background-color: rgb(20, 26, 34);
}

.ps-v2-stage-image {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    width: 100%;
    height: 100%;
}

.ps-v2-stage-fade {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 18%;
    background-color: rgba(8, 10, 14, 0.28);
}

.ps-v2-home-profile {
    position: absolute;
    left: 16px;
    top: 14px;
    max-width: 260px;
    padding: 8px 12px;
    background-color: rgba(8, 12, 18, 0.42);
    border-left-width: 2px;
    border-left-color: rgba(199, 145, 48, 0.7);
}

.ps-v2-home-profile .ps-title {
    font-size: 18px;
    color: rgb(248, 226, 177);
}

.ps-v2-home-profile .ps-body {
    font-size: 12px;
    color: rgb(191, 181, 155);
}

.ps-v2-facility-banner {
    position: absolute;
    left: 50%;
    top: 14px;
    translate: -50% 0;
    min-width: 140px;
    height: 34px;
    padding-left: 14px;
    padding-right: 14px;
    font-size: 17px;
    -unity-font-style: bold;
    -unity-text-align: middle-center;
    color: rgb(236, 226, 196);
    background-color: rgba(8, 12, 18, 0.34);
    border-top-width: 0;
    border-bottom-width: 0;
    border-left-width: 0;
    border-right-width: 0;
}

.ps-v2-facility-banner.ps-v2-facility-banner-ready {
    color: rgb(255, 244, 201);
    background-color: rgba(112, 63, 25, 0.55);
}

.ps-v2-home-dock {
    position: absolute;
    left: 18%;
    right: 18%;
    bottom: 28px;
    height: 48px;
    padding-left: 8px;
    padding-right: 8px;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    background-color: rgba(6, 8, 10, 0.38);
    border-top-width: 0;
}

.ps-v2-home-nav {
    width: 40px;
    min-width: 40px;
    height: 38px;
    margin-right: 4px;
    font-size: 16px;
    background-color: rgba(119, 75, 35, 0.12);
    color: rgb(230, 216, 178);
}

.ps-v2-facility-rail {
    flex-grow: 1;
    flex-direction: row;
    justify-content: center;
}

.ps-v2-facility-button {
    min-width: 88px;
    height: 38px;
    margin-left: 4px;
    margin-right: 4px;
    font-size: 13px;
    background-color: rgba(119, 75, 35, 0.08);
    color: rgb(196, 184, 156);
    border-left-width: 0;
    border-left-color: rgba(199, 145, 48, 0);
    transition-property: background-color, color, opacity;
    transition-duration: 0.12s;
    opacity: 0.72;
}

.ps-v2-facility-button.ps-selected {
    background-color: rgba(177, 96, 24, 0.28);
    border-left-color: rgb(255, 218, 130);
    color: rgb(255, 244, 201);
    opacity: 1;
}

.ps-v2-facility-button.ps-v2-facility-hotspot-ready {
    background-color: rgba(255, 210, 90, 0.22);
    color: rgb(255, 244, 201);
    opacity: 1;
}

.ps-v2-enter-building {
    position: absolute;
    left: 50%;
    bottom: 118px;
    translate: -50% 0;
    min-width: 220px;
    height: 48px;
    font-size: 18px;
    opacity: 0.35;
    background-color: rgba(119, 75, 35, 0.18);
    color: rgb(210, 198, 170);
}

.ps-v2-enter-building.ps-v2-enter-ready {
    opacity: 1;
    background-color: rgba(112, 63, 25, 0.94);
    color: rgb(255, 242, 201);
    border-left-color: rgb(255, 220, 110);
    border-right-color: rgb(255, 220, 110);
    border-top-color: rgb(255, 220, 110);
    border-bottom-color: rgb(255, 220, 110);
}

.ps-v2-home-hint {
    position: absolute;
    left: 24%;
    right: 24%;
    bottom: 6px;
    height: 22px;
    font-size: 11px;
    -unity-text-align: middle-center;
    color: rgba(170, 162, 142, 0.78);
}

.ps-v2-home-tabs {
    position: absolute;
    right: 14px;
    top: 14px;
    flex-direction: row;
}

.ps-v2-home-tab {
    min-width: 64px;
    height: 32px;
    margin-left: 5px;
    font-size: 12px;
    background-color: rgba(119, 75, 35, 0.12);
    color: rgb(230, 214, 172);
    border-left-width: 0;
}

.ps-v2-dev-access {
    position: absolute;
    left: 12px;
    bottom: 6px;
    width: 92px;
    height: 34px;
    font-size: 12px;
    background-color: rgba(12, 16, 20, 0.94);
    color: rgb(225, 210, 170);
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgb(148, 112, 58);
    border-right-color: rgb(148, 112, 58);
    border-top-color: rgb(148, 112, 58);
    border-bottom-color: rgb(148, 112, 58);
}

.ps-dev-access-global {
    position: absolute;
    left: 14px;
    bottom: 12px;
    width: 76px;
    height: 38px;
    font-size: 13px;
    background-color: rgb(22, 25, 29);
    color: rgb(255, 220, 135);
    border-left-width: 2px;
    border-right-width: 2px;
    border-top-width: 2px;
    border-bottom-width: 2px;
    border-left-color: rgb(190, 139, 56);
    border-right-color: rgb(190, 139, 56);
    border-top-color: rgb(190, 139, 56);
    border-bottom-color: rgb(190, 139, 56);
}

.ps-dev-panel-current {
    position: absolute;
    right: 14px;
    top: 14px;
    width: 390px;
    padding: 18px;
    background-color: rgba(18, 21, 24, 0.98);
    border-left-width: 2px;
    border-right-width: 2px;
    border-top-width: 2px;
    border-bottom-width: 2px;
    border-left-color: rgb(190, 139, 56);
    border-right-color: rgb(190, 139, 56);
    border-top-color: rgb(190, 139, 56);
    border-bottom-color: rgb(190, 139, 56);
}

.ps-dev-current-grid {
    flex-direction: row;
    flex-wrap: wrap;
    margin-top: 12px;
}

.ps-dev-current-button {
    width: 168px;
    height: 38px;
    margin: 4px;
}

.ps-dev-current-close {
    height: 38px;
    margin-top: 12px;
}

/* ===== Storage Rite (Obsidian Gold ﾃ・Steel Relic) ===== */
.ps-rite {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    flex-direction: column;
    padding: 12px 14px 10px 14px;
    background-color: rgb(92, 68, 44);
}

.ps-rite-stage-bg {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    opacity: 0.88;
}

.ps-rite-veil {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    background-color: rgba(4, 4, 6, 0.22);
}

.ps-rite-vignette-l {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 24%;
    background-color: rgba(2, 2, 4, 0.5);
}

.ps-rite-vignette-r {
    position: absolute;
    right: 0;
    top: 0;
    bottom: 0;
    width: 26%;
    background-color: rgba(2, 2, 4, 0.58);
}

.ps-rite-vignette-b {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 16%;
    background-color: rgba(2, 2, 4, 0.5);
}

.ps-rite-character {
    position: absolute;
    left: -5%;
    bottom: -12%;
    width: 34%;
    height: 102%;
    opacity: 1;
}

.ps-rite-character-layer {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
}

.ps-rite-char-far {
    left: 3%;
    right: -3%;
    top: 2%;
    bottom: -2%;
    opacity: 0.68;
}

.ps-rite-char-mid {
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    opacity: 0.92;
}

.ps-rite-char-near {
    left: -1.5%;
    right: 1.5%;
    top: -1.5%;
    bottom: 1.5%;
    opacity: 1;
}

.ps-rite-char-front {
    left: -2.5%;
    right: 2.5%;
    top: -2.5%;
    bottom: 2.5%;
    opacity: 1;
}

.ps-rite-top {
    flex-direction: row;
    align-items: center;
    height: 48px;
    min-height: 48px;
    margin-bottom: 8px;
    padding: 0 12px 0 14px;
    background-color: rgba(4, 4, 6, 0.9);
    border-left-width: 3px;
    border-right-width: 0;
    border-top-width: 0;
    border-bottom-width: 1px;
    border-left-color: rgb(212, 168, 72);
    border-bottom-color: rgba(198, 162, 86, 0.45);
    border-top-left-radius: 0;
    border-top-right-radius: 0;
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
}

.ps-rite-top-title {
    flex-direction: column;
    justify-content: center;
    margin-right: 16px;
    min-width: 140px;
}

.ps-rite-top > .ps-rite-top-title > .ps-title,
.ps-rite-top-title > .ps-title {
    font-size: 24px;
    color: rgb(242, 224, 180);
    margin-right: 0;
    margin-bottom: 0;
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
    -unity-font-style: bold;
    letter-spacing: 1px;
}

.ps-rite-top-sub {
    font-size: 10px;
    color: rgba(180, 165, 130, 0.7);
    margin-top: 1px;
    letter-spacing: 1px;
}

.ps-rite-loadouts,
.ps-rite-top-actions,
.ps-rite-cores,
.ps-rite-tools,
.ps-rite-kiln-rail,
.ps-rite-select-rail,
.ps-rite-filters {
    flex-direction: row;
    align-items: center;
    flex-wrap: wrap;
}

.ps-rite-loadouts {
    flex-grow: 1;
}

.ps-rite-top-actions {
    margin-left: auto;
}

.ps-rite-color-bar {
    flex-direction: row;
    align-items: center;
    flex-shrink: 0;
    height: 32px;
    min-height: 32px;
    margin-right: 12px;
    padding: 2px 10px;
    background-color: rgba(8, 8, 10, 0.92);
    border-top-left-radius: 0;
    border-top-right-radius: 0;
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
    border-left-width: 2px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(212, 168, 72, 0.75);
    border-right-color: rgba(160, 140, 90, 0.35);
    border-top-color: rgba(160, 140, 90, 0.35);
    border-bottom-color: rgba(160, 140, 90, 0.35);
}

.ps-rite-color-chip {
    flex-direction: row;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 24px;
    margin-left: 3px;
    margin-right: 3px;
    padding: 0 4px;
    background-color: rgba(0, 0, 0, 0);
    border-left-width: 0;
    border-right-width: 0;
    border-top-width: 0;
    border-bottom-width: 0;
}

.ps-rite-color-orb {
    width: 11px;
    height: 11px;
    margin-right: 5px;
    background-color: rgba(0, 0, 0, 0);
}

.ps-rite-color-value {
    font-size: 14px;
    color: rgb(246, 232, 196);
    -unity-font-style: bold;
    margin-bottom: 0;
}

.ps-rite-chip,
.ps-rite-tool,
.ps-rite-save,
.ps-rite-filter {
    height: 34px;
    min-height: 34px;
    margin-right: 6px;
    margin-bottom: 3px;
    padding-left: 14px;
    padding-right: 14px;
    font-size: 12px;
    letter-spacing: 1px;
    background-color: rgba(8, 7, 10, 0.92);
    color: rgb(230, 214, 170);
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(196, 160, 90, 0.55);
    border-right-color: rgba(196, 160, 90, 0.55);
    border-top-color: rgba(196, 160, 90, 0.55);
    border-bottom-color: rgba(196, 160, 90, 0.55);
    border-top-left-radius: 0;
    border-top-right-radius: 0;
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
    transition-property: background-color, border-left-color, border-right-color, border-top-color, border-bottom-color, color;
    transition-duration: 0.1s;
}

.ps-rite-chip:hover,
.ps-rite-tool:hover,
.ps-rite-save:hover,
.ps-rite-filter:hover {
    background-color: rgba(28, 22, 14, 0.96);
    border-left-color: rgb(232, 196, 110);
    border-right-color: rgb(232, 196, 110);
    border-top-color: rgb(232, 196, 110);
    border-bottom-color: rgb(232, 196, 110);
    color: rgb(255, 240, 200);
}

.ps-rite-equip-tile:hover,
.ps-rite-cell:hover,
.ps-rite-card:hover {
    background-color: rgba(40, 30, 16, 0.45);
    color: rgb(255, 240, 200);
}

.ps-rite-chip.ps-selected,
.ps-rite-filter.ps-selected {
    background-color: rgba(36, 26, 12, 0.96);
    border-left-color: rgb(240, 200, 110);
    border-right-color: rgb(240, 200, 110);
    border-top-color: rgb(240, 200, 110);
    border-bottom-color: rgb(240, 200, 110);
    color: rgb(255, 236, 186);
}

.ps-rite-equip-tile.ps-selected,
.ps-rite-card.ps-selected,
.ps-rite-cell.ps-selected {
    background-color: rgba(48, 34, 14, 0.4);
    border-left-color: rgb(240, 200, 110);
    border-right-color: rgb(240, 200, 110);
    border-top-color: rgb(240, 200, 110);
    border-bottom-color: rgb(240, 200, 110);
    color: rgb(255, 236, 186);
}

.ps-rite-tool-primary {
    background-color: rgba(18, 14, 8, 0.96);
    border-left-width: 3px;
    border-left-color: rgb(212, 168, 72);
    -unity-font-style: bold;
    min-width: 128px;
    color: rgb(246, 224, 170);
}

.ps-rite-save {
    background-color: rgba(22, 16, 8, 0.96);
    border-left-width: 3px;
    border-left-color: rgb(232, 186, 80);
    -unity-font-style: bold;
    font-size: 13px;
    min-width: 110px;
    color: rgb(255, 232, 176);
}

.ps-rite-body {
    flex-grow: 1;
    flex-direction: row;
    min-height: 0;
}

.ps-rite-left {
    width: 20%;
    min-width: 200px;
    max-width: 300px;
    min-height: 0;
    height: 100%;
    padding: 10px 8px;
    flex-direction: column;
    background-color: rgba(5, 5, 7, 0.88);
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(170, 150, 100, 0.35);
    border-right-color: rgba(170, 150, 100, 0.35);
    border-top-color: rgba(170, 150, 100, 0.35);
    border-bottom-color: rgba(170, 150, 100, 0.35);
    border-top-left-radius: 0;
    border-top-right-radius: 0;
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
}

.ps-rite-right {
    width: 24%;
    min-width: 230px;
    max-width: 360px;
    min-height: 0;
    height: 100%;
    padding: 10px 8px;
    flex-direction: column;
    background-color: rgba(4, 4, 6, 0.92);
    border-left-width: 3px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(212, 168, 72, 0.7);
    border-right-color: rgba(150, 130, 90, 0.35);
    border-top-color: rgba(150, 130, 90, 0.35);
    border-bottom-color: rgba(150, 130, 90, 0.35);
    border-top-left-radius: 0;
    border-top-right-radius: 0;
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
}

.ps-rite-template {
    flex-direction: column;
    flex-shrink: 0;
    margin-bottom: 12px;
    padding: 10px 8px;
    background-color: rgba(8, 8, 10, 0.94);
    border-left-width: 2px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(212, 168, 72, 0.75);
    border-right-color: rgba(150, 130, 90, 0.4);
    border-top-color: rgba(150, 130, 90, 0.4);
    border-bottom-color: rgba(150, 130, 90, 0.4);
}

.ps-rite-template-list-card {
    flex-direction: row;
    align-items: center;
    flex-shrink: 0;
    margin-bottom: 6px;
    padding: 8px 8px 8px 10px;
    background-color: rgba(8, 8, 10, 0.94);
    border-left-width: 2px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(140, 128, 96, 0.45);
    border-right-color: rgba(140, 128, 96, 0.35);
    border-top-color: rgba(140, 128, 96, 0.35);
    border-bottom-color: rgba(140, 128, 96, 0.35);
}

.ps-rite-template-list-card.ps-selected {
    border-left-color: rgb(255, 214, 120);
    border-right-color: rgba(212, 168, 72, 0.55);
    border-top-color: rgba(212, 168, 72, 0.55);
    border-bottom-color: rgba(212, 168, 72, 0.55);
    background-color: rgba(24, 18, 10, 0.96);
}

.ps-rite-template-list-main {
    flex-grow: 1;
    flex-shrink: 1;
    min-width: 0;
    flex-direction: column;
    margin-right: 8px;
}

.ps-rite-template-list-name,
.ps-rite-template-card-name {
    font-size: 16px;
    color: rgb(255, 232, 186);
    margin-bottom: 2px;
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
    white-space: normal;
}

.ps-rite-template-list-sub {
    font-size: 11px;
    color: rgba(170, 158, 128, 0.85);
    white-space: normal;
}

.ps-rite-template-actions {
    flex-direction: row;
    justify-content: flex-end;
    flex-shrink: 0;
    align-items: center;
}

.ps-rite-template-head {
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
    padding-bottom: 6px;
    border-bottom-width: 1px;
    border-bottom-color: rgba(198, 162, 86, 0.32);
}

.ps-rite-template-title {
    font-size: 13px;
    color: rgb(230, 200, 140);
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
}

.ps-rite-template-edit,
.ps-rite-template-decide {
    height: 28px;
    min-height: 28px;
    margin-left: 6px;
    margin-right: 0;
    margin-bottom: 0;
    padding-left: 10px;
    padding-right: 10px;
    font-size: 11px;
    letter-spacing: 1px;
    background-color: rgba(8, 8, 10, 0.95);
    color: rgb(236, 214, 168);
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(210, 170, 90, 0.75);
    border-right-color: rgba(210, 170, 90, 0.75);
    border-top-color: rgba(210, 170, 90, 0.75);
    border-bottom-color: rgba(210, 170, 90, 0.75);
    border-top-left-radius: 0;
    border-top-right-radius: 0;
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
}

.ps-rite-template-decide {
    background-color: rgba(48, 34, 16, 0.95);
    color: rgb(255, 232, 186);
    border-left-color: rgb(255, 214, 120);
    border-right-color: rgb(255, 214, 120);
    border-top-color: rgb(255, 214, 120);
    border-bottom-color: rgb(255, 214, 120);
}

.ps-rite-template-edit:hover,
.ps-rite-template-decide:hover {
    background-color: rgba(64, 44, 18, 0.98);
    border-left-color: rgb(255, 226, 150);
    border-right-color: rgb(255, 226, 150);
    border-top-color: rgb(255, 226, 150);
    border-bottom-color: rgb(255, 226, 150);
}

.ps-rite-template-row {
    flex-direction: row;
    align-items: center;
    min-height: 30px;
    margin-bottom: 3px;
    padding: 4px 8px;
    background-color: rgba(12, 12, 14, 0.9);
    border-left-width: 2px;
    border-right-width: 0;
    border-top-width: 0;
    border-bottom-width: 0;
    border-left-color: rgba(198, 162, 86, 0.4);
}

.ps-rite-template-kind {
    width: 40px;
    min-width: 40px;
    font-size: 11px;
    color: rgba(180, 160, 120, 0.9);
    margin-right: 8px;
}

.ps-rite-template-value {
    flex-grow: 1;
    font-size: 13px;
    color: rgb(246, 228, 186);
    -unity-font-style: bold;
    white-space: normal;
}

.ps-rite-panel-head,
.ps-rite-section-head {
    flex-direction: row;
    align-items: center;
    margin-bottom: 8px;
    padding-bottom: 6px;
    border-bottom-width: 1px;
    border-bottom-color: rgba(198, 162, 86, 0.28);
}

.ps-rite-left > .ps-title,
.ps-rite-right > .ps-title,
.ps-rite-center > .ps-title,
.ps-rite-panel-head > .ps-title {
    color: rgb(255, 232, 186);
    font-size: 18px;
    margin-bottom: 2px;
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
}

.ps-rite-left > .ps-body,
.ps-rite-right > .ps-body,
.ps-rite-center > .ps-body {
    color: rgb(198, 186, 158);
    font-size: 12px;
    margin-bottom: 6px;
    white-space: normal;
}

.ps-rite-left-header {
    flex-shrink: 0;
    flex-direction: column;
}

.ps-rite-left-header > .ps-rite-panel-head {
    flex-shrink: 0;
    margin-bottom: 6px;
}

.ps-rite-filters {
    flex-shrink: 0;
    margin-bottom: 8px;
}

.ps-rite-filter {
    height: 28px;
    min-height: 28px;
    font-size: 12px;
    padding-left: 10px;
    padding-right: 10px;
}

.ps-rite-equip-scroll {
    flex-grow: 1;
    min-height: 0;
    margin-top: 2px;
}

.ps-rite-equip-grid {
    flex-direction: row;
    flex-wrap: wrap;
    align-content: flex-start;
}

.ps-rite-equip-tile {
    position: relative;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    height: 102px;
    min-height: 102px;
    margin: 1.1%;
    padding: 6px 4px 4px 4px;
    background-color: rgba(10, 10, 12, 0.88);
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(150, 130, 90, 0.4);
    border-right-color: rgba(150, 130, 90, 0.4);
    border-top-color: rgba(150, 130, 90, 0.4);
    border-bottom-color: rgba(150, 130, 90, 0.4);
    border-top-left-radius: 0;
    border-top-right-radius: 0;
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
    transition-property: background-color, border-left-color, border-right-color, border-top-color, border-bottom-color, translate;
    transition-duration: 0.1s;
}

.ps-rite-equip-tile:hover {
    background-color: rgba(28, 22, 14, 0.94);
    border-left-color: rgb(230, 190, 110);
    border-right-color: rgb(230, 190, 110);
    border-top-color: rgb(230, 190, 110);
    border-bottom-color: rgb(230, 190, 110);
    translate: 0 -1px;
}

.ps-rite-equip-tile.ps-selected {
    background-color: rgba(36, 26, 12, 0.96);
    border-left-width: 2px;
    border-left-color: rgb(255, 214, 120);
    border-right-color: rgb(212, 168, 72);
    border-top-color: rgb(212, 168, 72);
    border-bottom-color: rgb(212, 168, 72);
}

.ps-rite-equip-placed {
    opacity: 0.55;
}

.ps-rite-equip-art {
    width: 64px;
    height: 64px;
    margin-bottom: 2px;
}

.ps-rite-equip-name {
    width: 100%;
    font-size: 10px;
    color: rgb(236, 220, 176);
    -unity-text-align: middle-center;
    white-space: normal;
    background-color: rgba(6, 4, 10, 0.55);
    padding-top: 2px;
    padding-bottom: 2px;
}

.ps-rite-center {
    flex-grow: 1;
    min-height: 0;
    flex-direction: column;
    margin-left: 10px;
    margin-right: 10px;
    padding: 4px 4px;
    background-color: rgba(0, 0, 0, 0);
    border-left-width: 0;
    border-right-width: 0;
    border-top-width: 0;
    border-bottom-width: 0;
    align-items: stretch;
}

.ps-rite-kiln-row {
    position: relative;
    flex-grow: 1;
    min-height: 0;
    flex-direction: column;
    align-items: stretch;
}

.ps-rite-kiln {
    flex-grow: 1;
    min-height: 0;
    min-width: 0;
    width: 100%;
    position: relative;
    flex-direction: column;
    justify-content: flex-start;
    align-items: stretch;
    margin-bottom: 6px;
    padding: 10px 10px 8px 10px;
    background-color: rgba(0, 0, 0, 0);
    border-top-left-radius: 0;
    border-top-right-radius: 0;
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
    overflow: hidden;
}

.ps-rite-select-dock {
    position: absolute;
    right: 10px;
    top: 14px;
    z-index: 40;
    flex-direction: column;
    align-items: stretch;
    justify-content: flex-start;
    flex-shrink: 0;
    width: 72px;
    min-width: 72px;
    margin: 0;
    padding: 8px 5px;
    background-color: rgba(4, 4, 6, 0.92);
    border-left-width: 2px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(212, 168, 72, 0.8);
    border-right-color: rgba(150, 130, 90, 0.45);
    border-top-color: rgba(150, 130, 90, 0.45);
    border-bottom-color: rgba(150, 130, 90, 0.45);
    border-top-left-radius: 0;
    border-top-right-radius: 0;
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
}

.ps-rite-select-btn {
    width: 100%;
    min-width: 0;
    height: 52px;
    min-height: 52px;
    margin-right: 0;
    margin-bottom: 6px;
    padding-left: 4px;
    padding-right: 4px;
    font-size: 11px;
    letter-spacing: 1px;
    white-space: normal;
    -unity-text-align: middle-center;
    background-color: rgba(10, 10, 12, 0.96);
    color: rgb(236, 214, 168);
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(196, 160, 90, 0.55);
    border-right-color: rgba(196, 160, 90, 0.55);
    border-top-color: rgba(196, 160, 90, 0.55);
    border-bottom-color: rgba(196, 160, 90, 0.55);
    border-top-left-radius: 0;
    border-top-right-radius: 0;
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
}

.ps-rite-select-btn:hover {
    background-color: rgba(40, 30, 14, 0.98);
    border-left-color: rgb(255, 214, 120);
    border-right-color: rgb(255, 214, 120);
    border-top-color: rgb(255, 214, 120);
    border-bottom-color: rgb(255, 214, 120);
    color: rgb(255, 240, 200);
}

.ps-rite-kiln-head {
    flex-direction: row;
    justify-content: center;
    align-items: center;
    flex-shrink: 0;
    margin-bottom: 4px;
    z-index: 3;
}

.ps-rite-color-orb {
    width: 18px;
    height: 18px;
    margin-right: 5px;
    background-color: rgba(0, 0, 0, 0);
}

.ps-rite-circle-layers {
    position: absolute;
    left: 2%;
    right: 2%;
    top: 0%;
    bottom: 0%;
    align-items: center;
    justify-content: center;
}

.ps-rite-circle-glow {
    position: absolute;
    left: 8%;
    right: 8%;
    top: 8%;
    bottom: 8%;
    background-color: rgba(120, 70, 180, 0.18);
    border-top-left-radius: 1000px;
    border-top-right-radius: 1000px;
    border-bottom-left-radius: 1000px;
    border-bottom-right-radius: 1000px;
    border-left-width: 0;
    border-right-width: 0;
    border-top-width: 0;
    border-bottom-width: 0;
}

.ps-rite-core-merchant .ps-rite-circle-glow { background-color: rgba(80, 140, 220, 0.2); }
.ps-rite-core-arcane .ps-rite-circle-glow { background-color: rgba(140, 90, 220, 0.22); }
.ps-rite-core-coffin .ps-rite-circle-glow { background-color: rgba(180, 70, 70, 0.2); }
.ps-rite-core-living .ps-rite-circle-glow { background-color: rgba(70, 170, 110, 0.2); }

.ps-rite-circle-art,
.ps-rite-circle-spin-art,
.ps-rite-circle-accent,
.ps-rite-circle-shape,
.ps-rite-circle-inner-spin {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    transform-origin: center;
}

.ps-rite-circle-accent,
.ps-rite-circle-shape {
    opacity: 0.85;
}

.ps-rite-circle-inner-spin {
    left: 8%;
    right: 8%;
    top: 8%;
    bottom: 8%;
    opacity: 0.7;
}

.ps-rite-circle-spin-art {
    opacity: 0.55;
}

.ps-rite-floats {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
}

.ps-rite-float {
    position: absolute;
    width: 5px;
    height: 5px;
    margin-left: -2px;
    margin-top: -2px;
    background-color: rgba(255, 236, 180, 0.9);
    border-top-left-radius: 5px;
    border-top-right-radius: 5px;
    border-bottom-left-radius: 5px;
    border-bottom-right-radius: 5px;
    border-left-width: 0;
    border-right-width: 0;
    border-top-width: 0;
    border-bottom-width: 0;
    opacity: 0.4;
    transform-origin: center;
}

.ps-rite-float-rune {
    width: 9px;
    height: 9px;
    margin-left: -4px;
    margin-top: -4px;
    border-top-left-radius: 2px;
    border-top-right-radius: 2px;
    border-bottom-left-radius: 2px;
    border-bottom-right-radius: 2px;
    background-color: rgba(255, 220, 140, 0.95);
}

.ps-rite-circle-crest {
    position: absolute;
    left: 36%;
    right: 36%;
    top: 36%;
    bottom: 36%;
    transform-origin: center;
    opacity: 0.8;
}

.ps-rite-sparks {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
}

.ps-rite-spark {
    position: absolute;
    width: 4px;
    height: 4px;
    margin-left: -2px;
    margin-top: -2px;
    background-color: rgba(255, 248, 220, 0.95);
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
    border-bottom-left-radius: 4px;
    border-bottom-right-radius: 4px;
    border-left-width: 0;
    border-right-width: 0;
    border-top-width: 0;
    border-bottom-width: 0;
    opacity: 0.35;
}

.ps-rite-spark-lg {
    width: 7px;
    height: 7px;
    margin-left: -3px;
    margin-top: -3px;
    background-color: rgba(255, 230, 160, 1);
}

.ps-rite-circle-label {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 3%;
    color: rgba(255, 232, 186, 0.72);
    font-size: 13px;
    -unity-text-align: middle-center;
    margin-top: 0;
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
}

.ps-rite-circle {
    flex-grow: 1;
    width: 72%;
    max-width: 560px;
    min-height: 0;
    justify-content: center;
    align-items: center;
    align-self: center;
    padding: 28px 18px 32px 18px;
    z-index: 2;
}

.ps-rite-kiln-rail,
.ps-rite-select-rail {
    justify-content: center;
    margin-top: 4px;
    margin-bottom: 2px;
}

.ps-rite-grid {
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: center;
    width: 100%;
    max-width: 520px;
}

.ps-rite-cell {
    position: relative;
    margin: 0.9%;
    padding: 0;
    min-width: 56px;
    min-height: 56px;
    background-color: rgba(8, 6, 12, 0.35);
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(140, 120, 80, 0.35);
    border-right-color: rgba(140, 120, 80, 0.35);
    border-top-color: rgba(180, 150, 90, 0.4);
    border-bottom-color: rgba(100, 80, 120, 0.35);
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
    border-bottom-left-radius: 6px;
    border-bottom-right-radius: 6px;
    align-items: center;
    justify-content: center;
    overflow: hidden;
}

.ps-rite-cell:hover {
    border-left-color: rgb(240, 200, 120);
    border-right-color: rgb(240, 200, 120);
    border-top-color: rgb(240, 200, 120);
    border-bottom-color: rgb(240, 200, 120);
}

.ps-rite-cell-plate {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
}

.ps-rite-orb-wrap {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    align-items: center;
    justify-content: center;
}

.ps-rite-orb-halo {
    position: absolute;
    width: 78%;
    height: 78%;
    border-top-left-radius: 1000px;
    border-top-right-radius: 1000px;
    border-bottom-left-radius: 1000px;
    border-bottom-right-radius: 1000px;
    border-left-width: 0;
    border-right-width: 0;
    border-top-width: 0;
    border-bottom-width: 0;
    opacity: 0.35;
}

.ps-rite-orb-halo.ps-element-fire { background-color: rgba(255, 110, 60, 0.45); }
.ps-rite-orb-halo.ps-element-water { background-color: rgba(70, 160, 255, 0.45); }
.ps-rite-orb-halo.ps-element-wind { background-color: rgba(90, 220, 130, 0.45); }
.ps-rite-orb-halo.ps-element-earth { background-color: rgba(230, 180, 70, 0.45); }

.ps-rite-orb-wrap-open .ps-rite-orb {
    width: 70%;
    height: 70%;
}

.ps-rite-orb-wrap-placed .ps-rite-orb {
    width: 78%;
    height: 78%;
    opacity: 0.55;
}

.ps-rite-orb {
    width: 70%;
    height: 70%;
    background-color: rgba(0, 0, 0, 0);
    border-left-width: 0;
    border-right-width: 0;
    border-top-width: 0;
    border-bottom-width: 0;
    transform-origin: center;
}

.ps-rite-orb-fallback {
    width: 58%;
    height: 58%;
    border-top-left-radius: 1000px;
    border-top-right-radius: 1000px;
    border-bottom-left-radius: 1000px;
    border-bottom-right-radius: 1000px;
}

.ps-rite-orb-fallback.ps-element-fire { background-color: rgb(255, 96, 64); }
.ps-rite-orb-fallback.ps-element-water { background-color: rgb(72, 150, 255); }
.ps-rite-orb-fallback.ps-element-wind { background-color: rgb(96, 210, 130); }
.ps-rite-orb-fallback.ps-element-earth { background-color: rgb(210, 170, 70); }

.ps-rite-cell-art {
    width: 68%;
    height: 68%;
    z-index: 2;
}

.ps-rite-status {
    color: rgb(198, 186, 158);
    font-size: 13px;
    margin-bottom: 8px;
    white-space: normal;
}

.ps-rite-status-active {
    color: rgb(255, 220, 96);
    -unity-font-style: bold;
}

.ps-rite-formula {
    margin-bottom: 0;
    padding: 0;
    background-color: rgba(0, 0, 0, 0);
    border-left-width: 0;
    border-right-width: 0;
    border-top-width: 0;
    border-bottom-width: 0;
}

.ps-rite-formula-row {
    flex-direction: row;
    flex-wrap: wrap;
    margin-bottom: 10px;
}

.ps-rite-popup-overlay {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    background-color: rgba(2, 2, 4, 0.78);
    justify-content: center;
    align-items: center;
}

.ps-rite-popup {
    width: 720px;
    max-width: 88%;
    max-height: 82%;
    padding: 16px 18px;
    background-color: rgb(8, 8, 10);
    border-left-width: 3px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgb(212, 168, 72);
    border-right-color: rgba(196, 160, 90, 0.7);
    border-top-color: rgba(196, 160, 90, 0.7);
    border-bottom-color: rgba(196, 160, 90, 0.7);
    border-top-left-radius: 0;
    border-top-right-radius: 0;
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
    flex-direction: column;
}

.ps-rite-popup-cards {
    width: 780px;
}

.ps-rite-popup-formula {
    width: 980px;
    max-width: 94%;
    height: 78%;
    max-height: 820px;
    padding: 14px 16px;
}

.ps-rite-formula-name {
    flex-direction: row;
    align-items: center;
    flex-shrink: 0;
    margin-bottom: 10px;
    padding: 8px 10px;
    background-color: rgba(6, 6, 8, 0.95);
    border-left-width: 2px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(212, 168, 72, 0.8);
    border-right-color: rgba(140, 128, 96, 0.4);
    border-top-color: rgba(140, 128, 96, 0.4);
    border-bottom-color: rgba(140, 128, 96, 0.4);
}

.ps-rite-formula-name-label {
    width: 64px;
    min-width: 64px;
    font-size: 12px;
    color: rgba(190, 170, 130, 0.9);
    margin-right: 10px;
    letter-spacing: 1px;
}

.ps-rite-formula-name-field {
    flex-grow: 1;
    height: 34px;
    min-height: 34px;
    margin: 0;
    padding: 0 8px;
    font-size: 16px;
    color: rgb(255, 232, 186);
    background-color: rgba(12, 12, 14, 0.98);
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(196, 160, 90, 0.55);
    border-right-color: rgba(196, 160, 90, 0.55);
    border-top-color: rgba(196, 160, 90, 0.55);
    border-bottom-color: rgba(196, 160, 90, 0.55);
    border-top-left-radius: 0;
    border-top-right-radius: 0;
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
}

.ps-rite-formula-name-field:focus {
    border-left-color: rgb(255, 214, 120);
    border-right-color: rgb(255, 214, 120);
    border-top-color: rgb(255, 214, 120);
    border-bottom-color: rgb(255, 214, 120);
}

.ps-rite-formula-name-field > .unity-text-field__input {
    background-color: rgba(0, 0, 0, 0);
    border-left-width: 0;
    border-right-width: 0;
    border-top-width: 0;
    border-bottom-width: 0;
    color: rgb(255, 232, 186);
    padding: 4px 2px;
    border-top-left-radius: 0;
    border-top-right-radius: 0;
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
}

.ps-rite-formula-body {
    flex-grow: 1;
    flex-direction: row;
    min-height: 0;
    margin-top: 2px;
}

.ps-rite-formula-rail {
    width: 280px;
    min-width: 240px;
    max-width: 320px;
    flex-shrink: 0;
    flex-direction: column;
    margin-right: 16px;
    padding-right: 8px;
    overflow: hidden;
}

.ps-rite-formula-acc {
    margin-bottom: 6px;
    background-color: rgba(8, 8, 10, 0.94);
    border-left-width: 2px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(160, 140, 90, 0.4);
    border-right-color: rgba(160, 140, 90, 0.35);
    border-top-color: rgba(160, 140, 90, 0.35);
    border-bottom-color: rgba(160, 140, 90, 0.35);
    border-top-left-radius: 0;
    border-top-right-radius: 0;
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
}

.ps-rite-formula-acc-open {
    border-left-color: rgb(240, 200, 120);
    border-right-color: rgb(240, 200, 120);
    border-top-color: rgb(240, 200, 120);
    border-bottom-color: rgb(240, 200, 120);
}

.ps-rite-formula-acc-head {
    flex-direction: row;
    align-items: center;
    height: 48px;
    min-height: 48px;
    margin: 0;
    padding: 0 10px;
    background-color: rgba(0, 0, 0, 0);
    border-left-width: 0;
    border-right-width: 0;
    border-top-width: 0;
    border-bottom-width: 0;
    color: rgb(246, 230, 188);
}

.ps-rite-formula-acc-head:hover {
    background-color: rgba(80, 52, 24, 0.45);
}

.ps-rite-formula-acc-mark {
    width: 18px;
    font-size: 14px;
    color: rgb(230, 190, 110);
    margin-right: 4px;
}

.ps-rite-formula-acc-kind {
    font-size: 13px;
    color: rgba(210, 190, 150, 0.85);
    margin-right: 10px;
    min-width: 64px;
}

.ps-rite-formula-acc-chosen {
    flex-grow: 1;
    font-size: 15px;
    -unity-font-style: bold;
    color: rgb(255, 232, 186);
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
    -unity-text-align: middle-right;
    white-space: normal;
}

.ps-rite-formula-acc-body {
    flex-direction: column;
    padding: 4px 8px 10px 8px;
    border-top-width: 1px;
    border-top-color: rgba(196, 150, 72, 0.25);
}

.ps-rite-formula-acc-desc {
    font-size: 11px;
    color: rgb(170, 158, 132);
    margin-bottom: 6px;
    white-space: normal;
}

.ps-rite-formula-acc-option {
    height: 36px;
    min-height: 36px;
    margin-bottom: 4px;
    padding-left: 10px;
    padding-right: 10px;
    font-size: 13px;
    background-color: rgba(12, 12, 14, 0.96);
    color: rgb(236, 220, 178);
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(160, 140, 90, 0.4);
    border-right-color: rgba(160, 140, 90, 0.4);
    border-top-color: rgba(160, 140, 90, 0.4);
    border-bottom-color: rgba(160, 140, 90, 0.4);
    border-top-left-radius: 0;
    border-top-right-radius: 0;
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
}

.ps-rite-formula-acc-option:hover {
    background-color: rgba(40, 30, 14, 0.95);
}

.ps-rite-formula-acc-option.ps-selected {
    background-color: rgba(48, 34, 14, 0.96);
    border-left-width: 2px;
    border-left-color: rgb(255, 214, 120);
    border-right-color: rgb(212, 168, 72);
    border-top-color: rgb(212, 168, 72);
    border-bottom-color: rgb(212, 168, 72);
    color: rgb(255, 246, 214);
}

.ps-rite-formula-stage {
    flex-grow: 1;
    min-width: 0;
    min-height: 0;
    position: relative;
    align-items: center;
    justify-content: center;
    background-color: rgba(4, 4, 6, 0.55);
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(160, 140, 90, 0.3);
    border-right-color: rgba(160, 140, 90, 0.3);
    border-top-color: rgba(160, 140, 90, 0.3);
    border-bottom-color: rgba(160, 140, 90, 0.3);
    border-top-left-radius: 0;
    border-top-right-radius: 0;
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
    overflow: hidden;
}

.ps-rite-formula-stage-hint {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 10px;
    font-size: 11px;
    color: rgba(200, 180, 140, 0.55);
    -unity-text-align: middle-center;
}

.ps-rite-popup-scroll {
    flex-grow: 1;
    min-height: 0;
    margin-top: 6px;
}

.ps-rite-popup > .ps-title {
    color: rgb(246, 228, 176);
    font-size: 24px;
}

.ps-rite-popup > .ps-body,
.ps-rite-formula > .ps-body {
    color: rgb(198, 186, 158);
    font-size: 13px;
    margin-bottom: 8px;
    white-space: normal;
}

.ps-rite-popup-header {
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
    flex-shrink: 0;
}

.ps-rite-popup-header > .ps-title {
    color: rgb(246, 228, 176);
    font-size: 24px;
    margin-right: 12px;
}

.ps-rite-circle-preview {
    position: absolute;
    left: 4%;
    right: 4%;
    top: 2%;
    bottom: 8%;
    height: auto;
    min-height: 0;
    margin-bottom: 0;
    overflow: hidden;
}

.ps-rite-drag-ghost {
    position: absolute;
    width: 72px;
    height: 72px;
    padding: 4px;
    background-color: rgba(20, 16, 24, 0.88);
    border-left-width: 2px;
    border-right-width: 2px;
    border-top-width: 2px;
    border-bottom-width: 2px;
    border-left-color: rgb(255, 210, 110);
    border-right-color: rgb(255, 210, 110);
    border-top-color: rgb(255, 210, 110);
    border-bottom-color: rgb(255, 210, 110);
}

.ps-rite-drag-ghost-art {
    width: 100%;
    height: 100%;
}

.ps-rite-equip-placed {
    opacity: 0.55;
}

.ps-rite-detail-art {
    width: 132px;
    height: 132px;
    margin-bottom: 10px;
    align-self: center;
    background-color: rgba(8, 8, 10, 0.7);
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(160, 140, 90, 0.4);
    border-right-color: rgba(160, 140, 90, 0.4);
    border-top-color: rgba(160, 140, 90, 0.4);
    border-bottom-color: rgba(160, 140, 90, 0.4);
    border-top-left-radius: 0;
    border-top-right-radius: 0;
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
    padding: 8px;
}

.ps-rite-shape {
    margin: 6px 0 10px 0;
    padding: 8px;
    background-color: rgba(0, 0, 0, 0.25);
    align-self: flex-start;
}

.ps-rite-shape-row {
    flex-direction: row;
}

.ps-rite-shape-cell {
    width: 28px;
    height: 28px;
    margin: 2px;
    border-top-left-radius: 3px;
    border-top-right-radius: 3px;
    border-bottom-left-radius: 3px;
    border-bottom-right-radius: 3px;
}

.ps-rite-shape-empty {
    background-color: rgba(255, 255, 255, 0.06);
}

.ps-rite-shape-filled {
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(255, 230, 160, 0.55);
    border-right-color: rgba(255, 230, 160, 0.55);
    border-top-color: rgba(255, 230, 160, 0.55);
    border-bottom-color: rgba(255, 230, 160, 0.55);
}

.ps-rite-cards {
    flex-direction: column;
    margin-top: 6px;
}

.ps-rite-card {
    min-height: 64px;
    margin-bottom: 6px;
    padding: 10px 12px;
    font-size: 13px;
    white-space: normal;
    -unity-text-align: middle-left;
    background-color: rgb(10, 10, 12);
    color: rgb(232, 216, 174);
    border-left-width: 2px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(160, 140, 90, 0.5);
    border-right-color: rgba(160, 140, 90, 0.4);
    border-top-color: rgba(160, 140, 90, 0.4);
    border-bottom-color: rgba(160, 140, 90, 0.4);
    border-top-left-radius: 0;
    border-top-right-radius: 0;
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
}

/* ===== Rite product chrome polish ===== */
.ps-rite-tick {
    position: absolute;
    width: 10px;
    height: 10px;
    border-left-color: rgb(232, 196, 110);
    border-right-color: rgb(232, 196, 110);
    border-top-color: rgb(232, 196, 110);
    border-bottom-color: rgb(232, 196, 110);
}

.ps-rite-tick-tl {
    left: 0;
    top: 0;
    border-left-width: 2px;
    border-top-width: 2px;
    border-right-width: 0;
    border-bottom-width: 0;
}

.ps-rite-tick-tr {
    right: 0;
    top: 0;
    border-right-width: 2px;
    border-top-width: 2px;
    border-left-width: 0;
    border-bottom-width: 0;
}

.ps-rite-tick-bl {
    left: 0;
    bottom: 0;
    border-left-width: 2px;
    border-bottom-width: 2px;
    border-right-width: 0;
    border-top-width: 0;
}

.ps-rite-tick-br {
    right: 0;
    bottom: 0;
    border-right-width: 2px;
    border-bottom-width: 2px;
    border-left-width: 0;
    border-top-width: 0;
}

.ps-rite-brand {
    flex-direction: row;
    align-items: center;
    flex-grow: 1;
    min-width: 0;
}

.ps-rite-brand-mark {
    width: 4px;
    height: 34px;
    margin-right: 12px;
    background-color: rgb(212, 168, 72);
    border-left-width: 0;
    border-right-width: 0;
    border-top-width: 0;
    border-bottom-width: 0;
}

.ps-rite-top {
    position: relative;
    height: 58px;
    min-height: 58px;
    margin-bottom: 10px;
    padding: 0 14px 0 12px;
    background-color: rgba(3, 3, 5, 0.94);
    border-left-width: 0;
    border-bottom-color: rgba(212, 168, 72, 0.38);
}

.ps-rite-top-eyebrow {
    font-size: 9px;
    color: rgba(180, 160, 110, 0.72);
    letter-spacing: 2px;
    margin-bottom: 1px;
}

.ps-rite-top-name {
    font-size: 22px;
    color: rgb(255, 236, 196);
    margin: 0;
    letter-spacing: 2px;
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
}

.ps-rite-top-sub {
    font-size: 10px;
    color: rgba(160, 148, 120, 0.68);
    margin-top: 1px;
    letter-spacing: 1px;
}

.ps-rite-left,
.ps-rite-right-shell,
.ps-rite-popup,
.ps-rite-kiln-rail {
    position: relative;
    overflow: hidden;
}

.ps-rite-left {
    width: 21%;
    min-width: 220px;
    max-width: 310px;
    padding: 12px 10px 10px 10px;
    background-color: rgba(4, 4, 6, 0.92);
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(150, 135, 95, 0.42);
    border-right-color: rgba(150, 135, 95, 0.42);
    border-top-color: rgba(150, 135, 95, 0.42);
    border-bottom-color: rgba(150, 135, 95, 0.42);
}

.ps-rite-right-shell {
    width: 25%;
    min-width: 240px;
    max-width: 370px;
    height: 100%;
    min-height: 0;
    flex-direction: column;
    background-color: rgba(3, 3, 5, 0.94);
    border-left-width: 3px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgb(212, 168, 72);
    border-right-color: rgba(140, 125, 90, 0.4);
    border-top-color: rgba(140, 125, 90, 0.4);
    border-bottom-color: rgba(140, 125, 90, 0.4);
}

.ps-rite-right {
    width: 100%;
    max-width: none;
    min-width: 0;
    height: 100%;
    padding: 12px 10px;
    background-color: rgba(0, 0, 0, 0);
    border-left-width: 0;
    border-right-width: 0;
    border-top-width: 0;
    border-bottom-width: 0;
}

.ps-rite-panel-head {
    flex-direction: row;
    align-items: center;
    flex-shrink: 1;
    flex-grow: 1;
    min-width: 0;
    margin-bottom: 8px;
    padding-bottom: 0;
    border-bottom-width: 0;
}

.ps-rite-panel-index {
    font-size: 11px;
    color: rgb(212, 168, 72);
    margin-right: 8px;
    letter-spacing: 1px;
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
}

.ps-rite-panel-title {
    font-size: 14px;
    color: rgb(246, 228, 186);
    margin-right: 8px;
    letter-spacing: 1px;
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
}

.ps-rite-panel-rule {
    flex-grow: 1;
    height: 1px;
    min-height: 1px;
    margin-top: 2px;
    background-color: rgba(198, 162, 86, 0.28);
    border-left-width: 0;
    border-right-width: 0;
    border-top-width: 0;
    border-bottom-width: 0;
}

.ps-rite-chip,
.ps-rite-tool,
.ps-rite-save,
.ps-rite-filter {
    height: 32px;
    min-height: 32px;
    margin-right: 5px;
    margin-bottom: 4px;
    padding-left: 12px;
    padding-right: 12px;
    font-size: 11px;
    letter-spacing: 1px;
    background-color: rgba(8, 8, 10, 0.96);
    color: rgb(220, 204, 164);
    border-left-color: rgba(170, 145, 90, 0.55);
    border-right-color: rgba(170, 145, 90, 0.55);
    border-top-color: rgba(170, 145, 90, 0.55);
    border-bottom-color: rgba(170, 145, 90, 0.55);
}

.ps-rite-save {
    min-width: 118px;
    background-color: rgba(28, 20, 8, 0.98);
    border-left-width: 3px;
    border-left-color: rgb(240, 196, 96);
    color: rgb(255, 236, 186);
    -unity-font-style: bold;
}

.ps-rite-tool-primary {
    min-width: 132px;
    background-color: rgba(22, 16, 8, 0.98);
    border-left-width: 3px;
    border-left-color: rgb(212, 168, 72);
    color: rgb(255, 232, 176);
    -unity-font-style: bold;
}

.ps-rite-filter {
    height: 26px;
    min-height: 26px;
    padding-left: 9px;
    padding-right: 9px;
    font-size: 11px;
    background-color: rgba(6, 6, 8, 0.9);
}

.ps-rite-filter.ps-selected {
    background-color: rgba(40, 28, 12, 0.98);
    border-left-color: rgb(255, 214, 120);
    border-right-color: rgb(255, 214, 120);
    border-top-color: rgb(255, 214, 120);
    border-bottom-color: rgb(255, 214, 120);
    color: rgb(255, 240, 200);
}

.ps-rite-equip-tile {
    height: 108px;
    min-height: 108px;
    margin: 1%;
    padding: 8px 4px 0 4px;
    background-color: rgba(8, 8, 10, 0.92);
    border-left-color: rgba(130, 118, 88, 0.45);
    border-right-color: rgba(130, 118, 88, 0.45);
    border-top-color: rgba(130, 118, 88, 0.45);
    border-bottom-color: rgba(130, 118, 88, 0.45);
}

.ps-rite-equip-tile.ps-selected {
    background-color: rgba(34, 24, 10, 0.98);
    border-left-width: 2px;
    border-left-color: rgb(255, 214, 120);
    border-right-color: rgb(212, 168, 72);
    border-top-color: rgb(212, 168, 72);
    border-bottom-color: rgb(212, 168, 72);
}

.ps-rite-equip-badge {
    position: absolute;
    left: 4px;
    top: 4px;
    padding: 1px 5px;
    font-size: 9px;
    letter-spacing: 1px;
    color: rgb(255, 230, 170);
    background-color: rgba(40, 28, 10, 0.92);
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(212, 168, 72, 0.7);
    border-right-color: rgba(212, 168, 72, 0.7);
    border-top-color: rgba(212, 168, 72, 0.7);
    border-bottom-color: rgba(212, 168, 72, 0.7);
}

.ps-rite-equip-name {
    font-size: 10px;
    color: rgb(220, 204, 164);
    background-color: rgba(2, 2, 4, 0.72);
    padding: 3px 2px;
    margin-top: 2px;
}

.ps-rite-equip-placed {
    opacity: 0.62;
}

.ps-rite-kiln-rail {
    flex-shrink: 0;
    justify-content: flex-start;
    align-items: center;
    min-height: 44px;
    margin-top: 6px;
    margin-bottom: 0;
    padding: 6px 10px;
    background-color: rgba(4, 4, 6, 0.9);
    border-left-width: 2px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(212, 168, 72, 0.7);
    border-right-color: rgba(140, 125, 90, 0.4);
    border-top-color: rgba(140, 125, 90, 0.4);
    border-bottom-color: rgba(140, 125, 90, 0.4);
}

.ps-rite-rail-spacer {
    flex-grow: 1;
    min-width: 8px;
    height: 1px;
}

.ps-rite-color-bar {
    height: 30px;
    min-height: 30px;
    margin-right: 0;
    background-color: rgba(0, 0, 0, 0);
    border-left-width: 0;
    border-right-width: 0;
    border-top-width: 0;
    border-bottom-width: 0;
}

.ps-rite-select-dock {
    position: absolute;
    right: 12px;
    top: 16px;
    z-index: 40;
    width: 78px;
    min-width: 78px;
    padding: 8px 6px 6px 6px;
    background-color: rgba(3, 3, 5, 0.94);
    border-left-width: 2px;
    border-left-color: rgb(212, 168, 72);
}

.ps-rite-select-caption {
    font-size: 9px;
    color: rgba(180, 160, 110, 0.75);
    letter-spacing: 2px;
    margin-bottom: 6px;
    -unity-text-align: middle-center;
}

.ps-rite-select-btn {
    height: 48px;
    min-height: 48px;
    margin-bottom: 5px;
    font-size: 11px;
    letter-spacing: 1px;
    background-color: rgba(10, 10, 12, 0.98);
    color: rgb(230, 214, 170);
}

.ps-rite-select-btn-primary {
    background-color: rgba(28, 20, 8, 0.98);
    border-left-width: 2px;
    border-left-color: rgb(240, 196, 96);
    color: rgb(255, 236, 186);
    -unity-font-style: bold;
}

.ps-rite-select-btn-danger {
    color: rgb(255, 196, 160);
    border-left-color: rgba(210, 120, 80, 0.7);
    border-right-color: rgba(210, 120, 80, 0.55);
    border-top-color: rgba(210, 120, 80, 0.55);
    border-bottom-color: rgba(210, 120, 80, 0.55);
}

.ps-rite-template-head {
    align-items: flex-start;
    margin-bottom: 10px;
    padding-bottom: 0;
    border-bottom-width: 0;
}

.ps-rite-template-head > .ps-rite-panel-head {
    flex-grow: 1;
    margin-bottom: 0;
    margin-right: 8px;
}

.ps-rite-template-list-card {
    min-height: 58px;
    margin-bottom: 7px;
    padding: 10px 8px 10px 12px;
    background-color: rgba(8, 8, 10, 0.96);
    border-left-width: 2px;
    border-left-color: rgba(150, 135, 95, 0.5);
}

.ps-rite-template-list-card.ps-selected {
    background-color: rgba(28, 20, 10, 0.98);
    border-left-color: rgb(255, 214, 120);
}

.ps-rite-template-list-name {
    font-size: 17px;
    letter-spacing: 1px;
}

.ps-rite-template-decide {
    min-width: 52px;
    background-color: rgba(40, 28, 10, 0.98);
    border-left-color: rgb(255, 214, 120);
    border-right-color: rgb(255, 214, 120);
    border-top-color: rgb(255, 214, 120);
    border-bottom-color: rgb(255, 214, 120);
    color: rgb(255, 236, 186);
    -unity-font-style: bold;
}

.ps-rite-template {
    padding: 12px 10px;
    margin-bottom: 14px;
    background-color: rgba(8, 8, 10, 0.96);
    border-left-width: 3px;
    border-left-color: rgb(212, 168, 72);
}

.ps-rite-template-save {
    width: 100%;
    min-width: 0;
    height: 36px;
    min-height: 36px;
    margin-top: 10px;
    margin-right: 0;
    margin-bottom: 0;
    -unity-text-align: middle-center;
}

.ps-rite-effect {
    flex-direction: column;
    flex-shrink: 0;
    margin-bottom: 7px;
    padding: 8px 10px;
    background-color: rgba(8, 8, 10, 0.94);
    border-left-width: 2px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(140, 128, 96, 0.45);
    border-right-color: rgba(140, 128, 96, 0.3);
    border-top-color: rgba(140, 128, 96, 0.3);
    border-bottom-color: rgba(140, 128, 96, 0.3);
}

.ps-rite-effect-active {
    background-color: rgba(28, 20, 10, 0.96);
    border-left-color: rgb(240, 196, 96);
    border-right-color: rgba(212, 168, 72, 0.45);
    border-top-color: rgba(212, 168, 72, 0.45);
    border-bottom-color: rgba(212, 168, 72, 0.45);
}

.ps-rite-effect-top {
    flex-direction: row;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 4px;
}

.ps-rite-effect-title {
    flex-grow: 1;
    flex-shrink: 1;
    min-width: 0;
    font-size: 13px;
    color: rgb(246, 228, 186);
    margin-right: 8px;
    white-space: normal;
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
}

.ps-rite-effect-badge {
    flex-shrink: 0;
    font-size: 10px;
    letter-spacing: 1px;
    color: rgba(170, 158, 128, 0.9);
    padding: 1px 5px;
    background-color: rgba(0, 0, 0, 0.35);
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(140, 128, 96, 0.45);
    border-right-color: rgba(140, 128, 96, 0.45);
    border-top-color: rgba(140, 128, 96, 0.45);
    border-bottom-color: rgba(140, 128, 96, 0.45);
}

.ps-rite-effect-badge-on {
    color: rgb(255, 230, 160);
    border-left-color: rgba(240, 196, 96, 0.8);
    border-right-color: rgba(240, 196, 96, 0.8);
    border-top-color: rgba(240, 196, 96, 0.8);
    border-bottom-color: rgba(240, 196, 96, 0.8);
    background-color: rgba(48, 34, 12, 0.85);
}

.ps-rite-effect-detail {
    font-size: 11px;
    color: rgba(180, 168, 140, 0.88);
    white-space: normal;
}

.ps-rite-empty {
    font-size: 12px;
    color: rgba(150, 140, 118, 0.78);
    margin: 6px 0 10px 0;
    padding: 10px;
    white-space: normal;
    background-color: rgba(8, 8, 10, 0.55);
    border-left-width: 2px;
    border-right-width: 0;
    border-top-width: 0;
    border-bottom-width: 0;
    border-left-color: rgba(140, 128, 96, 0.35);
}

.ps-rite-meta {
    font-size: 11px;
    color: rgba(170, 158, 128, 0.88);
    margin-bottom: 8px;
    white-space: normal;
}

.ps-rite-detail-card {
    flex-direction: column;
    align-items: center;
    margin-bottom: 12px;
    padding: 10px 8px;
    background-color: rgba(8, 8, 10, 0.9);
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(150, 135, 95, 0.4);
    border-right-color: rgba(150, 135, 95, 0.4);
    border-top-color: rgba(150, 135, 95, 0.4);
    border-bottom-color: rgba(150, 135, 95, 0.4);
}

.ps-rite-detail-name {
    font-size: 18px;
    color: rgb(255, 236, 196);
    margin: 4px 0 4px 0;
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
    -unity-text-align: middle-center;
}

.ps-rite-detail-desc {
    font-size: 12px;
    color: rgba(180, 168, 140, 0.9);
    white-space: normal;
    -unity-text-align: middle-center;
    margin-bottom: 2px;
}

.ps-rite-detail-art {
    width: 120px;
    height: 120px;
    margin-bottom: 6px;
    background-color: rgba(6, 6, 8, 0.8);
    border-left-color: rgba(160, 140, 90, 0.45);
    border-right-color: rgba(160, 140, 90, 0.45);
    border-top-color: rgba(160, 140, 90, 0.45);
    border-bottom-color: rgba(160, 140, 90, 0.45);
}

.ps-rite-cell {
    background-color: rgba(6, 6, 8, 0.42);
    border-left-color: rgba(140, 125, 90, 0.4);
    border-right-color: rgba(140, 125, 90, 0.4);
    border-top-color: rgba(170, 145, 95, 0.45);
    border-bottom-color: rgba(110, 100, 80, 0.4);
    border-top-left-radius: 0;
    border-top-right-radius: 0;
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
}

.ps-rite-popup {
    background-color: rgb(6, 6, 8);
    border-left-width: 3px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgb(212, 168, 72);
    border-right-color: rgba(170, 145, 95, 0.65);
    border-top-color: rgba(170, 145, 95, 0.65);
    border-bottom-color: rgba(170, 145, 95, 0.65);
}

.ps-rite-popup-title-block {
    flex-direction: column;
    flex-grow: 1;
    min-width: 0;
    margin-right: 12px;
}

.ps-rite-formula-acc {
    background-color: rgba(8, 8, 10, 0.96);
    border-left-width: 2px;
    border-left-color: rgba(160, 140, 90, 0.45);
}

.ps-rite-formula-acc-open {
    border-left-color: rgb(255, 214, 120);
    border-right-color: rgba(212, 168, 72, 0.55);
    border-top-color: rgba(212, 168, 72, 0.55);
    border-bottom-color: rgba(212, 168, 72, 0.55);
}

.ps-rite-right .unity-scroller,
.ps-rite-equip-scroll .unity-scroller {
    width: 8px;
}

.ps-rite-right .unity-scroller__slider,
.ps-rite-equip-scroll .unity-scroller__slider {
    background-color: rgba(20, 18, 14, 0.8);
}

.ps-rite-right .unity-scroller__tracker,
.ps-rite-equip-scroll .unity-scroller__tracker {
    background-color: rgba(212, 168, 72, 0.55);
}

/* ===== Expedition rite diagram (product HUD; sibling of storage rite) ===== */
.ps-xmap {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    flex-direction: column;
    background-color: rgb(92, 68, 44);
}

.ps-xmap-rite {
    background-color: rgb(92, 68, 44);
}

.ps-xmap-view {
    position: absolute;
    left: 372px;
    right: 0;
    top: 0;
    bottom: 0;
    background-color: rgb(92, 68, 44);
}

.ps-xmap-top-sub {
    font-size: 11px;
    color: rgba(170, 145, 95, 0.78);
    margin-top: 2px;
    letter-spacing: 1px;
}

.ps-xmap-sketch {
    position: absolute;
    right: 18px;
    bottom: 18px;
    width: 220px;
    height: 150px;
    padding: 8px 10px;
    background-color: rgba(12, 10, 14, 0.78);
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(180, 145, 80, 0.35);
    border-right-color: rgba(180, 145, 80, 0.35);
    border-top-color: rgba(180, 145, 80, 0.35);
    border-bottom-color: rgba(180, 145, 80, 0.35);
}

.ps-xmap-sketch-title {
    font-size: 10px;
    color: rgba(190, 165, 110, 0.85);
    margin-bottom: 4px;
    letter-spacing: 1px;
}

.ps-xmap-sketch-canvas {
    position: relative;
    flex-grow: 1;
    width: 100%;
    height: 110px;
    background-color: rgba(20, 18, 24, 0.5);
}

.ps-xmap-sketch-link {
    position: absolute;
    height: 2px;
    margin-left: 0;
    margin-top: -1px;
    background-color: rgba(210, 175, 95, 0.55);
    transform-origin: 0% 50%;
}

.ps-xmap-sketch-link-hidden {
    background-color: rgba(150, 130, 210, 0.55);
}

.ps-xmap-sketch-link-breach {
    background-color: rgba(180, 90, 120, 0.65);
}

.ps-xmap-sketch-pip {
    position: absolute;
    width: 8px;
    height: 8px;
    margin-left: -4px;
    margin-top: -4px;
    background-color: rgba(230, 200, 140, 0.9);
    border-radius: 0;
}

.ps-xmap-sketch-pip-mark {
    width: 10px;
    height: 10px;
    margin-left: -5px;
    margin-top: -5px;
    background-color: rgba(200, 140, 230, 0.95);
}

.ps-xmap-sketch-pip-current {
    width: 12px;
    height: 12px;
    margin-left: -6px;
    margin-top: -6px;
    background-color: rgba(255, 210, 90, 1);
}

.ps-xmap-view-frame {
    position: absolute;
    left: 372px;
    right: 0;
    top: 0;
    bottom: 0;
    border-left-width: 1px;
    border-left-color: rgba(198, 158, 78, 0.28);
    border-top-width: 0;
    border-right-width: 0;
    border-bottom-width: 0;
}

.ps-xmap-dock {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 372px;
    padding: 76px 16px 10px 16px;
    flex-direction: column;
    background-color: rgb(72, 52, 34);
    border-right-width: 1px;
    border-right-color: rgba(170, 135, 70, 0.55);
}

.ps-xmap-top {
    position: absolute;
    left: 12px;
    right: 12px;
    top: 10px;
    height: 54px;
    min-height: 54px;
    flex-direction: row;
    align-items: center;
    padding: 0 14px;
    background-color: rgba(54, 38, 24, 0.96);
    border-left-width: 2px;
    border-left-color: rgb(212, 168, 72);
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-right-color: rgba(150, 125, 80, 0.35);
    border-top-color: rgba(150, 125, 80, 0.35);
    border-bottom-color: rgba(150, 125, 80, 0.35);
}

.ps-xmap-top-actions {
    margin-left: auto;
    flex-direction: row;
    align-items: center;
}

.ps-xmap-top-actions > .ps-rite-chip {
    margin-right: 0;
    margin-left: 6px;
    margin-bottom: 0;
    min-width: 96px;
}

.ps-xmap-panel {
    flex-grow: 1;
    flex-shrink: 1;
    width: 100%;
    min-height: 220px;
    padding: 18px 18px 16px 18px;
    flex-direction: column;
    background-color: rgba(54, 38, 24, 0.94);
    border-left-width: 2px;
    border-left-color: rgb(212, 168, 72);
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-right-color: rgba(140, 115, 75, 0.32);
    border-top-color: rgba(140, 115, 75, 0.32);
    border-bottom-color: rgba(140, 115, 75, 0.32);
}

.ps-xmap-panel-eye {
    font-size: 10px;
    letter-spacing: 3px;
    color: rgba(170, 150, 105, 0.72);
    margin-bottom: 8px;
}

.ps-xmap-panel-type {
    font-size: 12px;
    color: rgb(210, 175, 95);
    margin-bottom: 4px;
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
}

.ps-xmap-panel-title {
    font-size: 26px;
    color: rgb(255, 238, 200);
    margin-bottom: 8px;
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
}

.ps-xmap-panel-status {
    font-size: 13px;
    color: rgb(230, 205, 145);
    margin-bottom: 12px;
    white-space: normal;
}

.ps-xmap-panel-rule {
    height: 1px;
    margin-bottom: 12px;
    background-color: rgba(180, 145, 75, 0.35);
    flex-shrink: 0;
}

.ps-xmap-panel-body {
    font-size: 14px;
    color: rgba(210, 195, 160, 0.95);
    white-space: normal;
    margin-bottom: 14px;
    flex-grow: 1;
}

.ps-xmap-panel-hint {
    font-size: 11px;
    color: rgba(145, 135, 112, 0.88);
    margin-bottom: 0;
    padding-top: 10px;
    border-top-width: 1px;
    border-top-color: rgba(120, 100, 65, 0.28);
    white-space: normal;
}

.ps-xmap-compass {
    flex-shrink: 0;
    width: 100%;
    margin-top: 12px;
    padding: 12px 10px 6px 10px;
    flex-direction: column;
    align-items: center;
    background-color: rgba(16, 13, 18, 0.9);
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(150, 120, 70, 0.35);
    border-right-color: rgba(150, 120, 70, 0.35);
    border-top-color: rgba(150, 120, 70, 0.35);
    border-bottom-color: rgba(150, 120, 70, 0.35);
}

.ps-xmap-compass-head {
    width: 100%;
    flex-direction: column;
    margin-bottom: 4px;
}

.ps-xmap-compass-title {
    font-size: 16px;
    color: rgb(255, 232, 186);
    margin-bottom: 2px;
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
}

.ps-xmap-compass-sub {
    font-size: 10px;
    color: rgba(160, 145, 110, 0.8);
    margin-bottom: 2px;
}

.ps-xmap-axis-row {
    width: 100%;
    flex-direction: row;
    justify-content: space-between;
    margin-top: 6px;
    margin-bottom: 2px;
}

.ps-xmap-axis-chip {
    flex-grow: 1;
    flex-direction: row;
    align-items: center;
    margin-left: 3px;
    margin-right: 3px;
    padding: 6px 8px;
    background-color: rgba(8, 7, 10, 0.75);
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(120, 100, 65, 0.35);
    border-right-color: rgba(120, 100, 65, 0.35);
    border-top-color: rgba(120, 100, 65, 0.35);
    border-bottom-color: rgba(120, 100, 65, 0.35);
}

.ps-xmap-axis-swatch {
    width: 8px;
    height: 8px;
    margin-right: 6px;
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
    border-bottom-left-radius: 4px;
    border-bottom-right-radius: 4px;
    background-color: rgb(200, 180, 120);
}

.ps-xmap-axis-alert > .ps-xmap-axis-swatch {
    background-color: rgb(210, 68, 42);
}

.ps-xmap-axis-collapse > .ps-xmap-axis-swatch {
    background-color: rgb(210, 150, 55);
}

.ps-xmap-axis-corruption > .ps-xmap-axis-swatch {
    background-color: rgb(140, 78, 190);
}

.ps-xmap-axis-name {
    font-size: 10px;
    color: rgba(180, 165, 130, 0.9);
    margin-right: 4px;
}

.ps-xmap-axis-value {
    font-size: 13px;
    color: rgb(245, 220, 160);
    margin-left: auto;
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
}

.ps-xmap-actions {
    flex-direction: row;
    align-items: center;
}

.ps-xmap-move {
    flex-grow: 1;
    margin-right: 8px;
    margin-bottom: 0;
    min-width: 140px;
}

.ps-xmap-mist {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    align-items: center;
    justify-content: center;
    background-color: rgba(4, 3, 6, 0.62);
}

.ps-xmap-mist-veil {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    background-color: rgba(2, 2, 4, 0.35);
}

.ps-xmap-mist-cloud {
    position: absolute;
    background-color: rgba(0, 0, 0, 0.42);
    border-top-left-radius: 120px;
    border-top-right-radius: 120px;
    border-bottom-left-radius: 120px;
    border-bottom-right-radius: 120px;
}

.ps-xmap-mist-cloud-0 {
    left: -8%;
    top: 8%;
    width: 48%;
    height: 34%;
}

.ps-xmap-mist-cloud-1 {
    right: -6%;
    top: 4%;
    width: 46%;
    height: 36%;
}

.ps-xmap-mist-cloud-2 {
    left: -10%;
    bottom: 6%;
    width: 52%;
    height: 38%;
}

.ps-xmap-mist-cloud-3 {
    right: -8%;
    bottom: 8%;
    width: 48%;
    height: 34%;
}

.ps-xmap-mist-panel {
    width: 52%;
    max-width: 680px;
    margin: 0;
}

.ps-xmap-stats {
    margin-left: 14px;
    margin-right: 10px;
    font-size: 12px;
    color: rgb(220, 198, 150);
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
    flex-shrink: 1;
    white-space: normal;
}

/* Shallow viewport: circle diameter ~300, center ~50px under the bottom edge */
.ps-xmap-gauge {
    width: 300px;
    height: 110px;
    align-self: center;
    background-color: rgba(0, 0, 0, 0);
    overflow: hidden;
}

.ps-xmap-gauge-dial {
    position: absolute;
    width: 300px;
    height: 300px;
    left: 0;
    bottom: -190px;
    background-color: rgba(34, 26, 16, 0.96);
    border-top-left-radius: 150px;
    border-top-right-radius: 150px;
    border-bottom-left-radius: 150px;
    border-bottom-right-radius: 150px;
    border-left-width: 3px;
    border-right-width: 3px;
    border-top-width: 3px;
    border-bottom-width: 3px;
    border-left-color: rgb(212, 168, 72);
    border-right-color: rgb(212, 168, 72);
    border-top-color: rgb(212, 168, 72);
    border-bottom-color: rgb(212, 168, 72);
}

.ps-xmap-gauge-rim {
    position: absolute;
    width: 276px;
    height: 276px;
    left: 12px;
    bottom: -178px;
    background-color: rgba(0, 0, 0, 0);
    border-top-left-radius: 138px;
    border-top-right-radius: 138px;
    border-bottom-left-radius: 138px;
    border-bottom-right-radius: 138px;
    border-left-width: 8px;
    border-right-width: 8px;
    border-top-width: 8px;
    border-bottom-width: 8px;
    border-left-color: rgba(210, 170, 90, 0.28);
    border-right-color: rgba(210, 170, 90, 0.28);
    border-top-color: rgba(210, 170, 90, 0.28);
    border-bottom-color: rgba(210, 170, 90, 0.28);
}

.ps-xmap-gauge-tick {
    position: absolute;
    left: 50%;
    bottom: -40px;
    width: 2px;
    height: 130px;
    margin-left: -1px;
    background-color: rgba(190, 160, 95, 0.4);
    transform-origin: 50% 100%;
}

.ps-xmap-gauge-tick-major {
    width: 3px;
    height: 138px;
    margin-left: -1.5px;
    background-color: rgba(235, 200, 120, 0.95);
}

.ps-xmap-gauge-num {
    position: absolute;
    width: 36px;
    margin-left: -18px;
    margin-top: -10px;
    font-size: 12px;
    color: rgb(245, 220, 160);
    -unity-text-align: middle-center;
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.9);
}

.ps-xmap-needle {
    position: absolute;
    left: 50%;
    bottom: -40px;
    width: 3px;
    height: 132px;
    margin-left: -1.5px;
    transform-origin: 50% 100%;
}

.ps-xmap-needle-alert {
    background-color: rgb(210, 68, 42);
    height: 136px;
    width: 3px;
}

.ps-xmap-needle-collapse {
    background-color: rgb(210, 150, 55);
    height: 112px;
    width: 2px;
}

.ps-xmap-needle-corruption {
    background-color: rgb(140, 78, 190);
    height: 88px;
    width: 2px;
}

.ps-xmap-gauge-hub {
    position: absolute;
    left: 50%;
    bottom: -47px;
    width: 14px;
    height: 14px;
    margin-left: -7px;
    background-color: rgb(220, 190, 120);
    border-top-left-radius: 7px;
    border-top-right-radius: 7px;
    border-bottom-left-radius: 7px;
    border-bottom-right-radius: 7px;
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgb(90, 70, 40);
    border-right-color: rgb(90, 70, 40);
    border-top-color: rgb(90, 70, 40);
    border-bottom-color: rgb(90, 70, 40);
}

.ps-xmap-finish {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    align-items: center;
    justify-content: center;
    background-color: rgba(4, 3, 6, 0.62);
}

.ps-xmap-finish-dialog {
    width: 48%;
    max-width: 560px;
    padding: 24px 26px;
    background-color: rgba(14, 12, 16, 0.97);
    border-left-width: 3px;
    border-left-color: rgb(212, 168, 72);
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-right-color: rgba(150, 125, 80, 0.35);
    border-top-color: rgba(150, 125, 80, 0.35);
    border-bottom-color: rgba(150, 125, 80, 0.35);
}

/* --- 2.5D route exploration (full-bleed stage, mini HUD) --- */
.ps-xmap-route {
    background-color: rgb(178, 184, 204);
}

.ps-xmap-route .ps-xmap-view {
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    background-color: rgb(178, 184, 204);
}

.ps-xmap-route .ps-xmap-view-frame {
    left: 0;
    display: none;
}

.ps-xmap-route .ps-xmap-top {
    display: none;
}

.ps-xmap-route .ps-xmap-dock {
    display: none;
}

.ps-xmap-hud {
    display: none;
}

.ps-xmap-mini {
    position: absolute;
    left: 14px;
    top: 12px;
    min-width: 120px;
    max-width: 220px;
    padding: 6px 8px;
    background-color: rgba(8, 9, 12, 0.52);
    border-left-width: 2px;
    border-left-color: rgba(212, 168, 72, 0.7);
    border-top-width: 1px;
    border-right-width: 1px;
    border-bottom-width: 1px;
    border-top-color: rgba(120, 100, 70, 0.25);
    border-right-color: rgba(120, 100, 70, 0.25);
    border-bottom-color: rgba(120, 100, 70, 0.25);
}

.ps-xmap-mini-name {
    font-size: 14px;
    color: rgb(245, 230, 190);
    margin-bottom: 2px;
}

.ps-xmap-mini-district {
    font-size: 11px;
    color: rgba(200, 185, 150, 0.85);
    margin-bottom: 4px;
    white-space: normal;
}

.ps-xmap-mini-row {
    flex-direction: row;
    align-items: center;
}

.ps-xmap-mini-bearing {
    font-size: 11px;
    color: rgba(180, 200, 210, 0.9);
    width: 22px;
    margin-right: 6px;
}

.ps-xmap-mini-info {
    width: 28px;
    height: 24px;
    min-width: 28px;
    font-size: 12px;
    padding: 0;
    background-color: rgba(30, 28, 24, 0.7);
    color: rgb(230, 210, 160);
}

.ps-xmap-detail {
    position: absolute;
    left: 14px;
    top: 86px;
    width: 240px;
    padding: 10px 12px;
    background-color: rgba(10, 10, 14, 0.88);
    border-left-width: 2px;
    border-left-color: rgba(212, 168, 72, 0.65);
}

.ps-xmap-detail-body {
    font-size: 12px;
    color: rgba(230, 215, 180, 0.92);
    white-space: normal;
}

.ps-xmap-axis-meter {
    position: absolute;
    right: 14px;
    bottom: 16px;
    width: 84px;
    height: 84px;
    background-color: rgba(8, 9, 12, 0.45);
    border-top-width: 1px;
    border-right-width: 1px;
    border-bottom-width: 1px;
    border-left-width: 1px;
    border-top-color: rgba(140, 120, 80, 0.35);
    border-right-color: rgba(140, 120, 80, 0.35);
    border-bottom-color: rgba(140, 120, 80, 0.35);
    border-left-color: rgba(140, 120, 80, 0.35);
    border-radius: 42px;
    align-items: center;
    justify-content: center;
}

.ps-xmap-axis-meter-dial {
    position: absolute;
    left: 10px;
    right: 10px;
    top: 10px;
    bottom: 10px;
    border-radius: 32px;
    background-color: rgba(20, 22, 28, 0.55);
    border-top-width: 1px;
    border-right-width: 1px;
    border-bottom-width: 1px;
    border-left-width: 1px;
    border-top-color: rgba(180, 150, 90, 0.35);
    border-right-color: rgba(180, 150, 90, 0.35);
    border-bottom-color: rgba(180, 150, 90, 0.35);
    border-left-color: rgba(180, 150, 90, 0.35);
}

.ps-xmap-axis-meter .ps-xmap-needle {
    bottom: 42px;
    height: 34px;
    width: 2px;
    margin-left: -1px;
}

.ps-xmap-axis-meter .ps-xmap-needle-alert {
    height: 36px;
}

.ps-xmap-axis-meter .ps-xmap-needle-collapse {
    height: 30px;
}

.ps-xmap-axis-meter .ps-xmap-needle-corruption {
    height: 24px;
}

.ps-xmap-axis-tip {
    position: absolute;
    right: 92px;
    bottom: 8px;
    min-width: 120px;
    padding: 8px 10px;
    background-color: rgba(10, 10, 14, 0.9);
    border-left-width: 2px;
    border-left-color: rgba(212, 168, 72, 0.7);
}

.ps-xmap-axis-tip-body {
    font-size: 11px;
    color: rgba(230, 215, 180, 0.95);
    white-space: normal;
}

.ps-xmap-confirm {
    position: absolute;
    width: 200px;
    padding: 12px 12px 10px 12px;
    background-color: rgba(12, 11, 16, 0.92);
    border-left-width: 2px;
    border-left-color: rgba(212, 168, 72, 0.8);
    border-top-width: 1px;
    border-right-width: 1px;
    border-bottom-width: 1px;
    border-top-color: rgba(140, 120, 80, 0.35);
    border-right-color: rgba(140, 120, 80, 0.35);
    border-bottom-color: rgba(140, 120, 80, 0.35);
}

.ps-xmap-confirm-title {
    font-size: 15px;
    color: rgb(245, 230, 190);
    margin-bottom: 4px;
}

.ps-xmap-confirm-kind {
    font-size: 12px;
    color: rgba(200, 170, 110, 0.95);
    margin-bottom: 6px;
}

.ps-xmap-confirm-body {
    font-size: 12px;
    color: rgba(220, 205, 170, 0.9);
    white-space: normal;
    margin-bottom: 4px;
}

.ps-xmap-confirm-delta {
    font-size: 11px;
    color: rgba(255, 180, 140, 0.95);
    white-space: normal;
    margin-bottom: 10px;
}

.ps-xmap-confirm-actions {
    flex-direction: row;
}

.ps-xmap-confirm-go {
    flex-grow: 1;
    margin-right: 6px;
    height: 32px;
    font-size: 13px;
}

.ps-xmap-confirm-back {
    flex-grow: 1;
    height: 32px;
    font-size: 13px;
    background-color: rgba(40, 38, 44, 0.9);
}

.ps-xmap-finish-chip {
    position: absolute;
    left: 14px;
    bottom: 16px;
    width: 96px;
    height: 30px;
    font-size: 12px;
    background-color: rgba(12, 12, 16, 0.55);
    color: rgba(220, 200, 160, 0.9);
}

.ps-dev-access-hint {
    left: auto;
    right: 10px;
    bottom: 10px;
    width: 72px;
    height: 26px;
    font-size: 11px;
    background-color: rgba(18, 20, 24, 0.55);
    color: rgba(210, 190, 140, 0.75);
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(160, 130, 70, 0.45);
    border-right-color: rgba(160, 130, 70, 0.45);
    border-top-color: rgba(160, 130, 70, 0.45);
    border-bottom-color: rgba(160, 130, 70, 0.45);
}

.ps-route-battle {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
}

.ps-route-battle-hero-hud {
    position: absolute;
    left: 18px;
    top: 58%;
    width: 160px;
    padding: 8px 10px;
    background-color: rgb(8, 10, 14);
    color: rgb(235, 225, 200);
    font-size: 13px;
    white-space: normal;
}

.ps-route-battle-enemy-hud {
    position: absolute;
    right: 18px;
    top: 58%;
    width: 180px;
    padding: 8px 10px;
    background-color: rgb(14, 8, 10);
    color: rgb(245, 210, 200);
    font-size: 13px;
    white-space: normal;
}

.ps-route-battle-intent {
    position: absolute;
    right: 18px;
    top: 18%;
    min-width: 160px;
    padding: 6px 10px;
    background-color: rgb(28, 10, 12);
    color: rgb(255, 190, 160);
    font-size: 13px;
}

.ps-route-battle-log {
    position: absolute;
    left: 22%;
    right: 22%;
    top: 52%;
    padding: 6px 10px;
    background-color: rgb(10, 10, 14);
    color: rgb(230, 220, 190);
    font-size: 13px;
    -unity-text-align: middle-center;
}

.ps-route-battle-bottom {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 42%;
    padding: 8px 14px 10px 14px;
    background-color: rgb(3, 3, 5);
    border-top-width: 1px;
    border-top-color: rgb(180, 140, 70);
    flex-direction: column;
}

.ps-route-battle-consumables {
    flex-direction: row;
    align-items: center;
    height: 40px;
    margin-bottom: 6px;
    background-color: rgb(5, 5, 7);
    padding-left: 6px;
    padding-right: 6px;
}

.ps-route-battle-cons-cap {
    margin-right: 8px;
    color: rgb(210, 190, 140);
    font-size: 12px;
}

.ps-route-battle-cons,
.ps-route-battle .ps-button.ps-route-battle-cons {
    min-width: 72px;
    height: 34px;
    margin-right: 6px;
    background-color: rgb(7, 7, 9);
    background-image: none;
    color: rgb(238, 228, 202);
    border-left-color: rgb(160, 130, 70);
    border-right-color: rgb(160, 130, 70);
    border-top-color: rgb(160, 130, 70);
    border-bottom-color: rgb(160, 130, 70);
}

.ps-route-battle-hand {
    flex-grow: 1;
    flex-direction: row;
    align-items: flex-end;
    justify-content: center;
    background-color: rgb(3, 3, 5);
}

.ps-route-battle-card,
.ps-route-battle .ps-button.ps-route-battle-card {
    width: 132px;
    height: 168px;
    margin-left: 4px;
    margin-right: 4px;
    white-space: normal;
    font-size: 11px;
    -unity-text-align: upper-center;
    background-color: rgb(6, 6, 8);
    background-image: none;
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgb(196, 160, 90);
    border-right-color: rgb(196, 160, 90);
    border-top-color: rgb(196, 160, 90);
    border-bottom-color: rgb(196, 160, 90);
    color: rgb(238, 228, 202);
}

.ps-route-battle-rail {
    flex-direction: row;
    align-items: center;
    height: 44px;
    margin-top: 4px;
    padding-left: 8px;
    padding-right: 8px;
    background-color: rgb(4, 4, 6);
}

.ps-route-battle-energy {
    flex-grow: 1;
    color: rgb(235, 210, 150);
    font-size: 14px;
    background-color: rgb(4, 4, 6);
}

.ps-route-battle-skill,
.ps-route-battle .ps-button.ps-route-battle-skill,
.ps-route-battle-end,
.ps-route-battle .ps-button.ps-route-battle-end {
    min-width: 140px;
    height: 38px;
    background-color: rgb(8, 8, 10);
    background-image: none;
    color: rgb(238, 228, 202);
    border-left-color: rgb(196, 160, 90);
    border-right-color: rgb(196, 160, 90);
    border-top-color: rgb(196, 160, 90);
    border-bottom-color: rgb(196, 160, 90);
}

.ps-route-battle-skill:disabled,
.ps-route-battle .ps-button.ps-route-battle-skill:disabled {
    color: rgba(180, 170, 150, 0.45);
    border-left-color: rgba(120, 100, 70, 0.45);
    border-right-color: rgba(120, 100, 70, 0.45);
    border-top-color: rgba(120, 100, 70, 0.45);
    border-bottom-color: rgba(120, 100, 70, 0.45);
}


.ps-xmap-hint-guide {
    position: absolute;
    left: 14px;
    bottom: 14px;
    width: 260px;
    padding: 8px 10px;
    background-color: rgba(8, 8, 12, 0.55);
    border-left-width: 2px;
    border-left-color: rgba(200, 160, 70, 0.65);
}

.ps-xmap-hint-guide-label {
    font-size: 11px;
    color: rgba(230, 215, 180, 0.9);
    white-space: normal;
}

.ps-route-reward {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    align-items: center;
    justify-content: center;
    background-color: rgba(4, 4, 8, 0.35);
}

.ps-route-reward-panel {
    width: 420px;
    padding: 18px 20px;
    background-color: rgba(12, 11, 16, 0.92);
    border-left-width: 3px;
    border-left-color: rgb(212, 168, 72);
    flex-direction: column;
}

.ps-route-reward-choice {
    margin-top: 8px;
    min-height: 56px;
    white-space: normal;
}

/* --- Large analog axis instrument (clipped into bottom-right) --- */
.ps-axis-instrument {
    position: absolute;
    right: -110px;
    bottom: -130px;
    width: 320px;
    height: 320px;
    overflow: visible;
}

/* Visible NW sector only 窶・keeps dialogue / choices from hitting the dial frame. */
.ps-axis-instrument-hit {
    position: absolute;
    left: 8px;
    top: 8px;
    width: 170px;
    height: 170px;
    background-color: rgba(0, 0, 0, 0);
}

.ps-axis-instrument-dim {
    opacity: 0.55;
}

.ps-axis-instrument-preview-focus {
    opacity: 1;
}

.ps-axis-instrument-danger .ps-axis-instrument-body {
    border-left-color: rgb(210, 90, 70);
    border-right-color: rgb(210, 90, 70);
    border-top-color: rgb(210, 90, 70);
    border-bottom-color: rgb(210, 90, 70);
}

.ps-axis-instrument-body {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    border-top-left-radius: 160px;
    border-top-right-radius: 160px;
    border-bottom-left-radius: 160px;
    border-bottom-right-radius: 160px;
    background-color: rgb(28, 24, 20);
    border-left-width: 3px;
    border-right-width: 3px;
    border-top-width: 3px;
    border-bottom-width: 3px;
    border-left-color: rgb(160, 130, 70);
    border-right-color: rgb(160, 130, 70);
    border-top-color: rgb(160, 130, 70);
    border-bottom-color: rgb(160, 130, 70);
    overflow: hidden;
}

.ps-axis-ring {
    position: absolute;
    left: 18px;
    right: 18px;
    top: 18px;
    bottom: 18px;
    border-top-left-radius: 140px;
    border-top-right-radius: 140px;
    border-bottom-left-radius: 140px;
    border-bottom-right-radius: 140px;
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(210, 180, 110, 0.35);
    border-right-color: rgba(210, 180, 110, 0.35);
    border-top-color: rgba(210, 180, 110, 0.35);
    border-bottom-color: rgba(210, 180, 110, 0.35);
}

.ps-axis-ring-mid {
    left: 42px;
    right: 42px;
    top: 42px;
    bottom: 42px;
    border-left-color: rgba(180, 90, 70, 0.4);
    border-right-color: rgba(180, 90, 70, 0.4);
    border-top-color: rgba(180, 90, 70, 0.4);
    border-bottom-color: rgba(180, 90, 70, 0.4);
}

.ps-axis-ring-inner {
    left: 68px;
    right: 68px;
    top: 68px;
    bottom: 68px;
    border-left-color: rgba(120, 90, 170, 0.45);
    border-right-color: rgba(120, 90, 170, 0.45);
    border-top-color: rgba(120, 90, 170, 0.45);
    border-bottom-color: rgba(120, 90, 170, 0.45);
}

.ps-axis-marks {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
}

.ps-axis-tick {
    position: absolute;
    left: 50%;
    top: 12px;
    width: 2px;
    height: 14px;
    margin-left: -1px;
    background-color: rgba(210, 185, 130, 0.55);
    transform-origin: 50% 148px;
}

.ps-axis-stamp {
    position: absolute;
    width: 28px;
    height: 28px;
    align-items: center;
    justify-content: center;
}

.ps-axis-stamp-alert { left: 36px; top: 48px; }
.ps-axis-stamp-collapse { right: 40px; top: 52px; }
.ps-axis-stamp-corruption { left: 50%; bottom: 54px; margin-left: -14px; }

.ps-axis-stamp-glyph {
    font-size: 16px;
    color: rgba(230, 210, 160, 0.85);
    -unity-text-align: middle-center;
}

.ps-axis-needle,
.ps-axis-ghost {
    position: absolute;
    left: 50%;
    bottom: 50%;
    width: 3px;
    height: 118px;
    margin-left: -1.5px;
    transform-origin: 50% 100%;
    background-color: rgb(220, 80, 50);
}

.ps-axis-needle-collapse { width: 2px; height: 104px; background-color: rgb(210, 150, 55); }
.ps-axis-needle-corruption { width: 2px; height: 90px; background-color: rgb(140, 90, 190); }

.ps-axis-ghost { opacity: 0.4; }
.ps-axis-ghost.ps-axis-needle-alert { background-color: rgba(255, 140, 100, 0.7); }
.ps-axis-ghost.ps-axis-needle-collapse { background-color: rgba(255, 200, 100, 0.65); }
.ps-axis-ghost.ps-axis-needle-corruption { background-color: rgba(190, 150, 255, 0.65); }

.ps-axis-glow {
    position: absolute;
    width: 48px;
    height: 48px;
    border-top-left-radius: 24px;
    border-top-right-radius: 24px;
    border-bottom-left-radius: 24px;
    border-bottom-right-radius: 24px;
    opacity: 0;
}

.ps-axis-glow-alert { left: 28px; top: 40px; background-color: rgba(220, 80, 50, 0.35); }
.ps-axis-glow-collapse { right: 32px; top: 44px; background-color: rgba(210, 150, 55, 0.35); }
.ps-axis-glow-corruption { left: 50%; bottom: 46px; margin-left: -24px; background-color: rgba(140, 90, 190, 0.35); }

.ps-axis-glow-danger {
    background-color: rgba(255, 90, 60, 0.55);
}

.ps-axis-crack {
    position: absolute;
    background-color: rgba(40, 30, 24, 0.85);
    opacity: 0;
}
.ps-axis-crack-a { left: 70px; top: 90px; width: 2px; height: 70px; rotate: 18deg; }
.ps-axis-crack-b { right: 80px; bottom: 100px; width: 2px; height: 60px; rotate: -24deg; }

.ps-axis-noise {
    position: absolute;
    left: 24px;
    right: 24px;
    top: 24px;
    bottom: 24px;
    border-top-left-radius: 130px;
    border-top-right-radius: 130px;
    border-bottom-left-radius: 130px;
    border-bottom-right-radius: 130px;
    background-color: rgba(255, 220, 160, 0.04);
    opacity: 0;
}

.ps-axis-instrument-tip {
    position: absolute;
    left: -200px;
    top: 10px;
    width: 190px;
    padding: 10px 12px;
    background-color: rgba(12, 11, 14, 0.92);
    border-left-width: 2px;
    border-left-color: rgb(180, 145, 75);
    /* Tip must never expand the instrument hit box. */
}

.ps-axis-instrument-tip-body {
    font-size: 11px;
    color: rgba(230, 215, 180, 0.95);
    white-space: normal;
}

/* Soft context HUD 窶・not a heavy black panel */
.ps-xmap-route .ps-xmap-mini {
    background-color: rgba(10, 10, 12, 0.28);
    border-left-width: 0;
    padding: 6px 8px;
    min-width: 100px;
    max-width: 200px;
}

.ps-xmap-route .ps-xmap-mini-name {
    font-size: 13px;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.75);
}

.ps-xmap-route .ps-xmap-axis-meter {
    display: none;
}

/* Bottom dialogue gradient layer */
.ps-route-dialogue {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
}

.ps-route-dialogue-veil {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 34%;
    background-color: rgba(4, 3, 6, 0.72);
}

.ps-route-dialogue-panel {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 30%;
    padding: 18px 28px 20px 28px;
    flex-direction: column;
    background-color: rgba(6, 5, 8, 0.55);
}

.ps-route-dialogue-speaker {
    font-size: 14px;
    color: rgb(220, 185, 110);
    margin-bottom: 6px;
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
}

.ps-route-dialogue-body {
    font-size: 15px;
    color: rgb(235, 225, 200);
    white-space: normal;
    margin-bottom: 12px;
    flex-shrink: 0;
}

.ps-route-dialogue-choices {
    flex-direction: column;
    flex-grow: 1;
}

.ps-route-choice-row {
    flex-direction: row;
    align-items: flex-start;
    margin-bottom: 6px;
    padding: 4px 2px;
    background-color: rgba(0, 0, 0, 0);
}

.ps-route-choice-mark {
    width: 22px;
    font-size: 15px;
    color: rgb(230, 190, 100);
}

.ps-route-choice-text {
    flex-grow: 1;
    font-size: 15px;
    color: rgba(220, 210, 185, 0.88);
    white-space: normal;
}

.ps-route-choice-hot .ps-route-choice-text {
    color: rgb(255, 240, 200);
    border-bottom-width: 1px;
    border-bottom-color: rgba(220, 180, 90, 0.7);
}

.ps-route-bubble {
    position: absolute;
    left: 18%;
    right: 30%;
    bottom: 38%;
    padding: 10px 14px;
    background-color: rgba(12, 11, 16, 0.82);
    border-left-width: 2px;
    border-left-color: rgb(200, 160, 80);
}

.ps-route-bubble-text {
    font-size: 14px;
    color: rgb(240, 230, 200);
    white-space: normal;
}

/* ===== Playable character roster ===== */
.ps-character-roster-grid {
    flex-direction: row;
    flex-wrap: wrap;
    margin-top: 8px;
}

.ps-character-roster-grid .ps-atlas-button,
.ps-character-roster-tile {
    width: 118px;
    margin-right: 10px;
    margin-bottom: 10px;
}

.ps-character-trait-box,
.ps-character-skill-box {
    margin-top: 14px;
    padding: 12px 14px;
    background-color: rgba(54, 38, 24, 0.72);
    border-left-width: 2px;
    border-left-color: rgb(212, 168, 72);
}

.ps-character-trait-name,
.ps-character-skill-name {
    font-size: 16px;
    color: rgb(255, 226, 160);
    margin-bottom: 4px;
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
}


/* ===== Battle scene (hand-first layout) ===== */
.ps-battle-screen {
    flex-grow: 1;
    position: relative;
    overflow: hidden;
    background-color: rgb(28, 22, 16);
}

.ps-battle-bg {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
}

.ps-battle-bg-scene { opacity: 1; }
.ps-battle-bg-far { opacity: 1; }
.ps-battle-bg-mid { opacity: 0.7; }

.ps-battle-bg-dim {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    background-color: rgba(6, 8, 12, 0.18);
}

.ps-battle-bg-ground-veil {
    position: absolute;
    left: 0;
    right: 0;
    top: 52%;
    bottom: 0;
    background-color: rgba(28, 20, 12, 0.12);
}

.ps-battle-start-banner {
    position: absolute;
    left: 18%;
    right: 18%;
    top: 38%;
    height: 92px;
    align-items: center;
    justify-content: center;
    background-color: rgba(4, 3, 2, 0.9);
    border-left-width: 3px;
    border-right-width: 3px;
    border-top-width: 2px;
    border-bottom-width: 2px;
    border-left-color: rgb(212, 176, 88);
    border-right-color: rgb(140, 108, 48);
    border-top-color: rgb(232, 196, 110);
    border-bottom-color: rgb(90, 68, 28);
    opacity: 0;
    translate: 0 14px;
    scale: 0.94 0.94 1;
    transition-property: opacity, translate, scale;
    transition-duration: 0.28s;
    transition-timing-function: ease-out;
    z-index: 40;
}

.ps-battle-start-banner-in {
    opacity: 1;
    translate: 0 0;
    scale: 1 1 1;
}

.ps-battle-start-banner-out {
    opacity: 0;
    translate: 0 -18px;
    scale: 1.04 1.04 1;
}

.ps-battle-start-title {
    font-size: 42px;
    color: rgb(236, 196, 96);
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
    -unity-text-align: middle-center;
    letter-spacing: 3px;
    -unity-font-style: bold;
    -unity-text-outline-width: 1px;
    -unity-text-outline-color: rgb(255, 255, 255);
}

.ps-battle-start-sub {
    margin-top: 2px;
    font-size: 18px;
    color: rgb(232, 188, 88);
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
    -unity-text-outline-width: 1px;
    -unity-text-outline-color: rgb(255, 255, 255);
    -unity-text-align: middle-center;
    letter-spacing: 2px;
}

/* Items — solid black panel from top-left corner */
.ps-battle-items {
    position: absolute;
    left: 0;
    top: 0;
    flex-direction: row;
    align-items: center;
    padding: 14px 18px 14px 14px;
    background-color: rgb(0, 0, 0);
    border-left-width: 0;
    border-right-width: 0;
    border-top-width: 0;
    border-bottom-width: 0;
    border-top-left-radius: 0;
    border-top-right-radius: 0;
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 10px;
    z-index: 20;
}

.ps-battle-cons {
    width: 72px;
    height: 72px;
    margin-right: 8px;
    padding: 6px;
    background-color: rgba(6, 5, 4, 0.9);
    border-left-width: 2px;
    border-right-width: 2px;
    border-top-width: 2px;
    border-bottom-width: 2px;
    border-left-color: rgb(196, 156, 72);
    border-right-color: rgb(120, 92, 40);
    border-top-color: rgb(212, 176, 88);
    border-bottom-color: rgb(90, 68, 28);
    border-top-left-radius: 2px;
    border-top-right-radius: 2px;
    border-bottom-left-radius: 2px;
    border-bottom-right-radius: 2px;
}

.ps-battle-cons:hover {
    background-color: rgba(18, 14, 8, 0.96);
    border-left-color: rgb(255, 214, 120);
    border-top-color: rgb(255, 220, 140);
}

.ps-battle-cons-art {
    width: 100%;
    height: 100%;
}

/* Actors */
.ps-battle-actor {
    position: absolute;
    align-items: center;
    justify-content: flex-end;
}

.ps-battle-actor-enemy {
    left: 32%;
    right: 16%;
    top: 6%;
    height: 50%;
    opacity: 0.92;
}

.ps-battle-actor-player {
    left: 15%;
    width: 26%;
    bottom: 4%;
    height: 58%;
}

.ps-battle-pedestal {
    position: absolute;
    left: 5%;
    right: 5%;
    bottom: 0;
    height: 28%;
    opacity: 0.55;
}

.ps-battle-actor-image {
    position: absolute;
    left: 4%;
    right: 4%;
    top: 0;
    bottom: 4%;
    background-color: rgba(0, 0, 0, 0);
    -unity-background-scale-mode: scale-to-fit;
}

.ps-battle-fx-layer {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    overflow: visible;
}

.ps-battle-floater {
    position: absolute;
    flex-direction: row;
    align-items: center;
    padding: 6px 12px 6px 8px;
    opacity: 0;
    translate: 0 18px;
    scale: 0.86 0.86 1;
    background-color: rgba(6, 4, 2, 0.72);
    border-left-width: 0;
    border-right-width: 0;
    border-top-width: 0;
    border-bottom-width: 0;
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
    border-bottom-left-radius: 4px;
    border-bottom-right-radius: 4px;
    transition-property: opacity, translate, scale;
    transition-duration: 0.28s;
    transition-timing-function: ease-out;
}

.ps-battle-floater-pop {
    opacity: 1;
    translate: 0 -8px;
    scale: 1.08 1.08 1;
}

.ps-battle-floater-out {
    opacity: 0;
    translate: 0 -56px;
    scale: 0.92 0.92 1;
}

.ps-battle-floater-icon-art {
    width: 34px;
    height: 34px;
    margin-right: 6px;
    background-color: rgba(0, 0, 0, 0);
    -unity-background-scale-mode: scale-to-fit;
}

.ps-battle-floater-value {
    font-size: 30px;
    color: rgb(255, 244, 214);
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
    -unity-text-outline-width: 1px;
    -unity-text-outline-color: rgba(20, 10, 4, 0.85);
}

.ps-battle-floater-damage .ps-battle-floater-value {
    color: rgb(255, 140, 110);
}

.ps-battle-floater-block .ps-battle-floater-value {
    color: rgb(140, 205, 255);
}

.ps-battle-floater-heal .ps-battle-floater-value {
    color: rgb(140, 230, 150);
}

.ps-battle-floater-energy .ps-battle-floater-value {
    color: rgb(255, 220, 120);
}

.ps-battle-floater-self .ps-battle-floater-value {
    color: rgb(230, 160, 120);
}

.ps-battle-floater-power .ps-battle-floater-value,
.ps-battle-floater-skill .ps-battle-floater-value {
    color: rgb(240, 210, 140);
    font-size: 22px;
}

.ps-battle-actor-hit {
    translate: 10px 0;
    transition-property: translate;
    transition-duration: 0.08s;
}

.ps-battle-actor-player.ps-battle-actor-hit {
    translate: -8px 0;
}

.ps-battle-actor-guard {
    scale: 1.04 1.04 1;
    transition-property: scale;
    transition-duration: 0.12s;
}

.ps-battle-actor-heal {
    translate: 0 -6px;
    transition-property: translate;
    transition-duration: 0.12s;
}

.ps-battle-card-flight {
    position: absolute;
    width: 120px;
    height: 44px;
    align-items: center;
    justify-content: center;
    background-color: rgba(28, 20, 12, 0.92);
    border-left-width: 2px;
    border-left-color: rgb(212, 168, 72);
    opacity: 1;
    transition-property: left, top, opacity, scale;
    transition-duration: 0.24s;
    transition-timing-function: ease-in;
}

.ps-battle-card-flight-attack {
    border-left-color: rgb(240, 120, 90);
}

.ps-battle-card-flight-support {
    border-left-color: rgb(120, 180, 230);
}

.ps-battle-card-flight-name {
    font-size: 14px;
    color: rgb(255, 236, 196);
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
}

/* Player / Enemy meter plates — same chrome layout */
.ps-battle-hud-player,
.ps-battle-hud-enemy {
    position: absolute;
    width: 132px;
    flex-direction: column;
    align-items: center;
    padding: 12px 8px 10px 8px;
    background-color: rgba(18, 14, 10, 0.92);
    border-left-width: 2px;
    border-right-width: 2px;
    border-top-width: 2px;
    border-bottom-width: 2px;
    border-left-color: rgb(196, 156, 72);
    border-right-color: rgb(120, 92, 40);
    border-top-color: rgb(212, 176, 88);
    border-bottom-color: rgb(90, 68, 28);
}

.ps-battle-hud-player {
    left: 1%;
    bottom: 8%;
    z-index: 14;
}

.ps-battle-hud-enemy {
    right: 1.2%;
    top: 2%;
    z-index: 18;
}

.ps-battle-player-meta,
.ps-battle-enemy-meta {
    width: 100%;
    margin-bottom: 8px;
    align-items: center;
}

.ps-battle-hud-player .ps-battle-hud-name,
.ps-battle-hud-enemy .ps-battle-hud-name {
    font-size: 20px;
    color: rgb(236, 196, 96);
    -unity-text-align: middle-center;
    white-space: normal;
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
    -unity-font-style: bold;
    -unity-text-outline-width: 1px;
    -unity-text-outline-color: rgb(255, 255, 255);
    letter-spacing: 1px;
}

.ps-battle-hud-player .ps-battle-hud-meta,
.ps-battle-hud-enemy .ps-battle-hud-meta {
    position: relative;
    right: auto;
    top: auto;
    font-size: 13px;
    color: rgb(232, 188, 88);
    -unity-text-align: middle-center;
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
    -unity-font-style: bold;
    -unity-text-outline-width: 1px;
    -unity-text-outline-color: rgb(255, 255, 255);
    letter-spacing: 1px;
}

.ps-battle-vbars {
    flex-direction: row;
    align-items: flex-end;
    justify-content: center;
    height: 248px;
    margin-bottom: 4px;
}

/* Intent badge — separate from meter plates, left of enemy HUD */
.ps-battle-intent-badge {
    position: absolute;
    right: 148px;
    top: 6%;
    width: 128px;
    min-width: 128px;
    height: auto;
    padding: 12px 10px;
    align-items: center;
    justify-content: center;
    background-color: rgba(18, 14, 10, 0.92);
    border-left-width: 2px;
    border-right-width: 2px;
    border-top-width: 2px;
    border-bottom-width: 2px;
    border-left-color: rgb(212, 176, 88);
    border-right-color: rgb(120, 92, 40);
    border-top-color: rgb(232, 196, 110);
    border-bottom-color: rgb(90, 68, 28);
    z-index: 18;
}

.ps-battle-intent-next {
    font-size: 12px;
    color: rgb(236, 196, 96);
    -unity-text-align: middle-center;
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
    -unity-font-style: bold;
    letter-spacing: 2px;
    -unity-text-outline-width: 1px;
    -unity-text-outline-color: rgb(255, 255, 255);
}

.ps-battle-intent-row {
    flex-direction: column;
    align-items: center;
    justify-content: center;
    margin-top: 4px;
    margin-bottom: 4px;
}

.ps-battle-intent-icon {
    width: 40px;
    height: 40px;
    margin-right: 0;
    margin-bottom: 4px;
}

.ps-battle-intent-value {
    font-size: 36px;
    color: rgb(236, 196, 96);
    -unity-text-align: middle-center;
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
    -unity-font-style: bold;
    -unity-text-outline-width: 1px;
    -unity-text-outline-color: rgb(255, 255, 255);
    letter-spacing: 0;
}

.ps-battle-intent-value-special {
    color: rgb(170, 210, 255);
}

.ps-battle-intent-kind {
    font-size: 15px;
    color: rgb(236, 196, 96);
    -unity-text-align: middle-center;
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
    -unity-font-style: bold;
    letter-spacing: 1px;
    -unity-text-outline-width: 1px;
    -unity-text-outline-color: rgb(255, 255, 255);
}

.ps-battle-intent-hint {
    margin-top: 6px;
    font-size: 12px;
    color: rgb(232, 188, 88);
    -unity-text-align: middle-center;
    white-space: normal;
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
    -unity-font-style: bold;
    -unity-text-outline-width: 1px;
    -unity-text-outline-color: rgb(255, 255, 255);
}

.ps-battle-meter {
    margin-top: 4px;
    height: 20px;
    position: relative;
}

.ps-battle-meter-track {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    background-color: rgba(0, 0, 0, 0.88);
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(140, 110, 50, 0.7);
    border-right-color: rgba(140, 110, 50, 0.7);
    border-top-color: rgba(140, 110, 50, 0.7);
    border-bottom-color: rgba(140, 110, 50, 0.7);
}

.ps-battle-meter-fill {
    position: absolute;
    left: 2px;
    top: 2px;
    bottom: 2px;
    width: 0%;
}

.ps-battle-meter-hp .ps-battle-meter-fill { background-color: rgb(232, 54, 48); }
.ps-battle-meter-block .ps-battle-meter-fill { background-color: rgb(56, 176, 232); }

.ps-battle-meter-label {
    display: none;
}

.ps-battle-meter-v {
    width: 52px;
    height: 248px;
    margin-top: 0;
    margin-left: 4px;
    margin-right: 4px;
}

.ps-battle-meter-v .ps-battle-meter-track {
    left: 0;
    right: 0;
    top: 0;
    bottom: 22px;
}

.ps-battle-meter-framed { background-color: rgba(0, 0, 0, 0); }

.ps-battle-meter-framed .ps-battle-meter-track {
    left: 30%;
    right: 30%;
    top: 14%;
    bottom: 26%;
    background-color: rgba(4, 3, 2, 0.95);
    border-left-width: 0;
    border-right-width: 0;
    border-top-width: 0;
    border-bottom-width: 0;
    border-top-left-radius: 10px;
    border-top-right-radius: 10px;
    border-bottom-left-radius: 10px;
    border-bottom-right-radius: 10px;
    overflow: hidden;
}

.ps-battle-meter-frame {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
}

.ps-battle-meter-v .ps-battle-meter-fill {
    left: 1px;
    right: 1px;
    width: auto;
    top: auto;
    bottom: 1px;
    height: 0%;
}

.ps-battle-meter-caption {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 1%;
    height: 14%;
    font-size: 14px;
    color: rgb(236, 196, 96);
    -unity-text-align: middle-center;
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
    -unity-font-style: bold;
    -unity-text-outline-width: 1px;
    -unity-text-outline-color: rgb(255, 255, 255);
    letter-spacing: 1px;
}

.ps-battle-status-row {
    flex-direction: row;
    flex-wrap: wrap;
    margin-top: 4px;
    min-height: 0;
    align-items: center;
    justify-content: center;
}

.ps-battle-status-chip {
    width: 26px;
    height: 26px;
    margin-right: 4px;
    margin-bottom: 2px;
    align-items: center;
    justify-content: center;
    position: relative;
    background-color: rgba(8, 6, 4, 0.96);
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgb(176, 140, 64);
    border-right-color: rgb(120, 92, 40);
    border-top-color: rgb(196, 156, 72);
    border-bottom-color: rgb(90, 68, 28);
}

.ps-battle-status-buff {
    border-left-color: rgb(120, 168, 96);
    border-right-color: rgb(88, 128, 72);
    border-top-color: rgb(148, 196, 110);
    border-bottom-color: rgb(70, 100, 55);
}

.ps-battle-status-debuff {
    border-left-color: rgb(196, 96, 82);
    border-right-color: rgb(140, 70, 60);
    border-top-color: rgb(220, 120, 100);
    border-bottom-color: rgb(100, 50, 42);
}

.ps-battle-status-chip Label {
    font-size: 13px;
    color: rgb(255, 230, 170);
}

.ps-battle-status-count {
    position: absolute;
    right: -4px;
    bottom: -4px;
    min-width: 13px;
    height: 13px;
    font-size: 9px;
    color: rgb(12, 8, 4);
    background-color: rgb(212, 176, 88);
    -unity-text-align: middle-center;
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
}

/* Skill / End Turn — black-gold chrome plates */
.ps-battle-skill-col {
    position: absolute;
    left: 34%;
    bottom: 78px;
    width: 170px;
    flex-direction: column;
    align-items: center;
    z-index: 30;
}

.ps-battle-btn,
.ps-battle .ps-button.ps-battle-btn {
    min-width: 0;
    min-height: 0;
    width: 100%;
    height: 46px;
    margin-right: 0;
    margin-bottom: 0;
    padding-left: 10px;
    padding-right: 10px;
    background-color: rgba(0, 0, 0, 0);
    background-image: none;
    color: rgb(236, 196, 96);
    border-left-width: 0;
    border-right-width: 0;
    border-top-width: 0;
    border-bottom-width: 0;
    border-top-left-radius: 0;
    border-top-right-radius: 0;
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
    font-size: 20px;
    letter-spacing: 2px;
    white-space: normal;
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
    -unity-font-style: bold;
    -unity-text-outline-width: 1px;
    -unity-text-outline-color: rgb(255, 255, 255);
    translate: 0 0;
}

.ps-battle-btn:hover,
.ps-battle .ps-button.ps-battle-btn:hover {
    translate: 0 0;
    background-color: rgba(0, 0, 0, 0);
    color: rgb(255, 220, 130);
    border-left-color: rgba(0, 0, 0, 0);
    border-right-color: rgba(0, 0, 0, 0);
    border-top-color: rgba(0, 0, 0, 0);
    border-bottom-color: rgba(0, 0, 0, 0);
    -unity-background-image-tint-color: rgb(255, 255, 255);
}

.ps-battle-btn:disabled,
.ps-battle .ps-button.ps-battle-btn:disabled {
    opacity: 0.42;
}

.ps-battle-btn-skill,
.ps-battle .ps-button.ps-battle-btn-skill {
    width: 150px;
    height: 150px;
    min-width: 150px;
    min-height: 150px;
    margin-bottom: 0;
    padding-left: 0;
    padding-right: 0;
    padding-top: 0;
    padding-bottom: 0;
    font-size: 22px;
    letter-spacing: 2px;
    color: rgb(236, 196, 96);
    -unity-text-align: middle-center;
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
    -unity-font-style: bold;
    -unity-text-outline-width: 1px;
    -unity-text-outline-color: rgb(255, 255, 255);
    background-color: rgba(0, 0, 0, 0);
    background-image: resource("Art/Battle/Chrome/btn-plate-hex");
    -unity-background-scale-mode: stretch-to-fill;
    -unity-background-image-tint-color: rgb(255, 255, 255);
    border-left-width: 0;
    border-right-width: 0;
    border-top-width: 0;
    border-bottom-width: 0;
    overflow: visible;
}

.ps-battle-btn-skill:hover,
.ps-battle .ps-button.ps-battle-btn-skill:hover {
    color: rgb(255, 220, 130);
    -unity-background-image-tint-color: rgb(255, 255, 255);
}

.ps-battle-hand-meta {
    position: absolute;
    right: 3%;
    bottom: 4px;
    max-width: 68%;
    flex-direction: row;
    align-items: center;
    justify-content: flex-end;
    padding: 6px 10px;
    background-color: rgb(8, 6, 4);
    border-left-width: 2px;
    border-right-width: 2px;
    border-top-width: 2px;
    border-bottom-width: 2px;
    border-left-color: rgb(196, 156, 72);
    border-right-color: rgb(120, 92, 40);
    border-top-color: rgb(212, 176, 88);
    border-bottom-color: rgb(90, 68, 28);
    z-index: 32;
}

.ps-battle-hand-meta-info {
    margin-right: 10px;
    margin-bottom: 0;
    font-size: 15px;
    color: rgb(236, 196, 96);
    -unity-text-align: middle-right;
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
    -unity-font-style: bold;
    -unity-text-outline-width: 1px;
    -unity-text-outline-color: rgb(255, 255, 255);
    letter-spacing: 1px;
}

.ps-battle-btn-end,
.ps-battle .ps-button.ps-battle-btn-end {
    width: 200px;
    min-width: 200px;
    height: 56px;
    min-height: 56px;
    margin-left: 0;
    margin-bottom: 0;
    padding-left: 0;
    padding-right: 0;
    padding-top: 0;
    padding-bottom: 0;
    font-size: 18px;
    letter-spacing: 2px;
    color: rgb(236, 196, 96);
    -unity-text-align: middle-center;
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
    -unity-font-style: bold;
    -unity-text-outline-width: 1px;
    -unity-text-outline-color: rgb(255, 255, 255);
    background-image: resource("Art/Battle/Chrome/btn-plate-wide");
    -unity-background-scale-mode: stretch-to-fill;
    -unity-background-image-tint-color: rgb(255, 255, 255);
    border-left-width: 0;
    border-right-width: 0;
    border-top-width: 0;
    border-bottom-width: 0;
}

/* Fan hand — sits above the bottom chrome; draws over enemy HUD when overlapping */
.ps-battle-hand {
    position: absolute;
    right: 4%;
    bottom: 78px;
    width: 72%;
    height: 300px;
    overflow: visible;
    z-index: 28;
}

.ps-battle-card {
    position: absolute;
    width: 168px;
    height: 236px;
    padding: 0;
    background-color: rgba(0, 0, 0, 0);
    border-left-width: 0;
    border-right-width: 0;
    border-top-width: 0;
    border-bottom-width: 0;
    color: rgb(245, 230, 200);
    white-space: normal;
    -unity-text-align: upper-center;
    transform-origin: 50% 100%;
    transition-property: translate, scale;
    transition-duration: 0.14s;
    transition-timing-function: ease-out;
    z-index: 28;
}

.ps-battle-card:hover {
    translate: 0 -30px;
    scale: 1.06 1.06 1;
}

.ps-battle-card-disabled { opacity: 0.68; }

.ps-battle-card-cost {
    position: absolute;
    left: 4%;
    top: 2%;
    width: 24%;
    height: 24%;
    font-size: 22px;
    color: rgb(236, 196, 96);
    -unity-text-align: middle-center;
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
    -unity-font-style: bold;
    -unity-text-outline-width: 1px;
    -unity-text-outline-color: rgb(255, 255, 255);
}

.ps-battle-card-art {
    position: absolute;
    left: 14%;
    right: 14%;
    top: 9%;
    height: 50%;
    background-color: rgba(4, 4, 6, 0.55);
    align-items: center;
    justify-content: center;
}

.ps-battle-card-art-image { width: 78%; height: 78%; }
.ps-battle-card-art-disabled { opacity: 0.42; }

.ps-battle-card-name {
    position: absolute;
    left: 12%;
    right: 12%;
    top: 62%;
    height: 8%;
    font-size: 16px;
    color: rgb(236, 196, 96);
    -unity-text-align: middle-center;
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
    -unity-font-style: bold;
    -unity-text-outline-width: 1px;
    -unity-text-outline-color: rgb(255, 255, 255);
}

.ps-battle-card-text {
    position: absolute;
    left: 11%;
    right: 11%;
    top: 70.5%;
    height: 16%;
    font-size: 14px;
    color: rgb(232, 188, 88);
    white-space: normal;
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
    -unity-text-outline-width: 1px;
    -unity-text-outline-color: rgb(255, 255, 255);
}

.ps-battle-card-foot {
    position: absolute;
    left: 9%;
    right: 9%;
    bottom: 4%;
    height: 8%;
    flex-direction: row;
}

.ps-battle-card-source {
    flex-grow: 1;
    font-size: 11px;
    color: rgb(236, 196, 96);
    -unity-text-align: middle-center;
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
    -unity-text-outline-width: 1px;
    -unity-text-outline-color: rgb(255, 255, 255);
}

.ps-battle-card-durability {
    width: 30%;
    font-size: 11px;
    color: rgb(232, 188, 88);
    -unity-text-align: middle-center;
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
    -unity-text-outline-width: 1px;
    -unity-text-outline-color: rgb(255, 255, 255);
}

.ps-battle-card-durability-low { color: rgb(255, 130, 100); }

.ps-battle-card-lock {
    position: absolute;
    right: 6%;
    top: 4%;
    min-width: 48px;
    height: 20px;
    padding-left: 5px;
    padding-right: 5px;
    background-color: rgba(102, 36, 42, 0.95);
    font-size: 11px;
    color: rgb(236, 196, 96);
    -unity-text-align: middle-center;
    -unity-font-definition: resource("Fonts/KleeOne-SemiBold");
    -unity-text-outline-width: 1px;
    -unity-text-outline-color: rgb(255, 255, 255);
}

.ps-hub-home-character-portrait {
    width: 88%;
    height: 88%;
    -unity-background-scale-mode: scale-to-fit;
}
